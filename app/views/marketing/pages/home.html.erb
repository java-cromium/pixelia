<!-- Hero Section -->
<section class="relative bg-brand-bg overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-20 left-10 w-72 h-72 bg-brand-highlight/20 rounded-full blur-3xl"></div>
