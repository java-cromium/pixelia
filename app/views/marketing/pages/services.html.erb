<% content_for(:title) { "Servicios — Pixelia" } %>

<!-- Services Hero -->
<section class="relative bg-slate-900 py-24 overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-10 right-20 w-80 h-80 bg-indigo-600/15 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-72 h-72 bg-cyan-500/10 rounded-full blur-3xl"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-6 text-center">
    <h1 class="text-4xl lg:text-6xl font-extrabold tracking-tight text-slate-50">Nuestros Servicios</h1>
    <p class="mt-6 text-lg text-slate-400 max-w-2xl mx-auto">
      Del concepto a la conversión — nos encargamos de cada capa de tu estrategia digital.
    </p>
  </div>
</section>

<!-- Servicios Principales -->
<section class="bg-slate-900 py-24 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-3 gap-8">

      <!-- Diseño y Desarrollo Web -->
      <a href="/servicios/diseno-web" class="group block p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 hover:border-indigo-500/40 hover:bg-slate-800 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-300">
        <div class="w-14 h-14 bg-indigo-600/15 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-50 mb-3 group-hover:text-indigo-400 transition-colors">Diseño y Desarrollo Web</h3>
        <p class="text-slate-400 leading-relaxed mb-4">Sitios web responsivos y de alto rendimiento, construidos a medida. Incluye optimización SEO, integración con analítica y mantenimiento continuo.</p>
        <span class="text-sm font-medium text-cyan-400 group-hover:text-cyan-300 transition-colors">Conoce más &rarr;</span>
      </a>

      <!-- E-Commerce -->
      <a href="/servicios/ecommerce" class="group block p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 hover:border-cyan-500/40 hover:bg-slate-800 hover:shadow-lg hover:shadow-cyan-500/5 transition-all duration-300">
        <div class="w-14 h-14 bg-cyan-500/15 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-50 mb-3 group-hover:text-cyan-400 transition-colors">E-Commerce (Tiendas Online)</h3>
        <p class="text-slate-400 leading-relaxed mb-4">Tiendas Shopify y WooCommerce con gestión de catálogos, pasarelas de pago seguras y dashboards de ventas en tiempo real.</p>
        <span class="text-sm font-medium text-cyan-400 group-hover:text-cyan-300 transition-colors">Conoce más &rarr;</span>
      </a>

      <!-- Gestión Integral y Posicionamiento -->
      <a href="/servicios/gestion-integral" class="group block p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 hover:border-indigo-500/40 hover:bg-slate-800 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-300">
        <div class="w-14 h-14 bg-indigo-600/15 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-50 mb-3 group-hover:text-indigo-400 transition-colors">Gestión Integral y Posicionamiento</h3>
        <p class="text-slate-400 leading-relaxed mb-4">SEO técnico, optimización de contenido, campañas de adquisición y ecosistema digital conectado con métricas centralizadas.</p>
        <span class="text-sm font-medium text-cyan-400 group-hover:text-cyan-300 transition-colors">Conoce más &rarr;</span>
      </a>

    </div>
  </div>
</section>

<!-- Capacidades Adicionales -->
<section class="bg-slate-900 py-24 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-slate-50">También incluimos</h2>
      <p class="mt-4 text-slate-400 max-w-xl mx-auto">Capacidades transversales que potencian cada uno de nuestros servicios.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="flex gap-4 p-6 rounded-2xl bg-slate-800/50 border border-slate-700/50">
        <div class="flex-shrink-0 w-10 h-10 bg-cyan-500/15 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
        </div>
        <div>
          <h4 class="font-bold text-slate-50 mb-1">Publicidad Digital</h4>
          <p class="text-sm text-slate-400">Google Ads, Meta Ads y estrategias de retargeting con reportes transparentes de ROI.</p>
        </div>
      </div>
      <div class="flex gap-4 p-6 rounded-2xl bg-slate-800/50 border border-slate-700/50">
        <div class="flex-shrink-0 w-10 h-10 bg-indigo-600/15 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
        </div>
        <div>
          <h4 class="font-bold text-slate-50 mb-1">Redes Sociales</h4>
          <p class="text-sm text-slate-400">Calendarios de contenido, gestión de comunidad y analítica de engagement en todas las plataformas.</p>
        </div>
      </div>
      <div class="flex gap-4 p-6 rounded-2xl bg-slate-800/50 border border-slate-700/50">
        <div class="flex-shrink-0 w-10 h-10 bg-cyan-500/15 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <div>
          <h4 class="font-bold text-slate-50 mb-1">Analítica 360°</h4>
          <p class="text-sm text-slate-400">Dashboards unificados que combinan tráfico web, ventas e-commerce y rendimiento de campañas.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-slate-800 py-20 border-t border-slate-700/50">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold text-slate-50">Construyamos tu estrategia digital</h2>
    <p class="mt-4 text-slate-400 text-lg">Cuéntanos tus objetivos y te recomendaremos la combinación de servicios ideal para ti.</p>
    <a href="/contact" class="mt-8 inline-block px-10 py-4 bg-indigo-600 text-slate-50 font-semibold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 hover:shadow-xl hover:shadow-indigo-500/30 transition-all duration-200">
      Contáctanos
    </a>
  </div>
</section>
