<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin — Pixelia" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-slate-900 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-64 bg-slate-950 text-slate-50 flex flex-col flex-shrink-0 border-r border-slate-800">
        <div class="px-6 py-6 border-b border-slate-800 flex items-center gap-3">
          <a href="<%= admin_root_path %>" class="flex items-center">
            <%= image_tag "logo-square.png", alt: "Pixelia", class: "h-14 w-auto" %>
          </a>
          <span class="text-xs font-medium text-cyan-400 bg-cyan-500/10 px-2 py-0.5 rounded-full">Admin</span>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-1">
          <%= admin_nav_link "Dashboard", admin_root_path, "dashboard" %>
          <%= admin_nav_link "Accounts", admin_accounts_path, "accounts" %>
          <%= admin_nav_link "Users", admin_users_path, "users" %>
          <%= admin_nav_link "Leads", admin_leads_path, "leads" %>
          <%= admin_nav_link "Stores", admin_ecommerce_stores_path, "stores" %>
          <%= admin_nav_link "Sites", admin_sites_path, "sites" %>

          <div class="pt-4 mt-4 border-t border-slate-800">
            <a href="/sidekiq" target="_blank" class="flex items-center gap-3 px-3 py-2 text-sm text-slate-500 hover:text-cyan-400 hover:bg-slate-800 rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Sidekiq Jobs
            </a>
          </div>
        </nav>

        <div class="px-4 py-4 border-t border-slate-800">
          <div class="text-xs text-slate-500 mb-2"><%= current_user.email %></div>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs text-red-400 hover:text-red-300" %>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-auto">
        <% if notice.present? %>
          <div class="mx-8 mt-6 p-4 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-400 text-sm font-medium flex items-center justify-between" data-controller="notification" data-notification-delay-value="5000">
            <span><%= notice %></span>
            <button data-action="click->notification#dismiss" class="text-emerald-400 hover:text-emerald-300 ml-4">&times;</button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-8 mt-6 p-4 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-sm font-medium flex items-center justify-between" data-controller="notification" data-notification-delay-value="8000">
            <span><%= alert %></span>
            <button data-action="click->notification#dismiss" class="text-red-400 hover:text-red-300 ml-4">&times;</button>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
