<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Portal — Pixelia" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <script>
      (function() {
        var theme = localStorage.getItem("pixelia_theme") || "dark";
        if (theme === "dark") document.documentElement.classList.add("dark");
        else document.documentElement.classList.remove("dark");
      })();
    </script>
  </head>

  <body class="bg-slate-50 dark:bg-slate-900 min-h-screen transition-colors duration-200">
    <div class="flex min-h-screen" data-controller="theme">
      <!-- Sidebar -->
      <aside class="w-64 bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-50 flex flex-col flex-shrink-0 border-r border-slate-200 dark:border-slate-800 transition-colors duration-200">
        <div class="px-6 py-6 border-b border-slate-200 dark:border-slate-800 flex items-center gap-3">
          <a href="<%= portal_root_path %>" class="flex items-center">
            <%= image_tag "logo-square.png", alt: "Pixelia", class: "h-14 w-auto" %>
          </a>
          <span class="text-xs font-medium text-cyan-600 dark:text-cyan-400 bg-cyan-500/10 px-2 py-0.5 rounded-full">Portal</span>
        </div>

        <nav class="flex-1 px-4 py-6 space-y-1">
          <a href="<%= portal_root_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= current_page?(portal_root_path) ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            <span>Dashboard</span>
          </a>
          <a href="<%= portal_sites_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= current_page?(portal_sites_path) ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            <span>Sites</span>
          </a>
          <a href="<%= portal_ecommerce_stores_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= current_page?(portal_ecommerce_stores_path) ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
            <span>Stores</span>
          </a>
          <a href="<%= portal_google_campaigns_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= request.path.start_with?('/google_campaigns') ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
            <span>Google Ads</span>
          </a>
          <a href="<%= portal_meta_campaigns_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= request.path.start_with?('/meta_campaigns') ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <span>Meta Ads</span>
          </a>
          <a href="<%= portal_chats_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= request.path.start_with?('/chats') ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            <span>AI Chat</span>
          </a>
          <a href="<%= portal_billing_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= current_page?(portal_billing_path) ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            <span>Billing</span>
          </a>
          <a href="<%= portal_settings_path %>" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition-colors <%= current_page?(portal_settings_path) ? 'font-semibold text-cyan-600 dark:text-cyan-400 bg-cyan-500/10' : 'text-slate-600 dark:text-slate-400 hover:text-cyan-600 dark:hover:text-cyan-400 hover:bg-slate-100 dark:hover:bg-slate-800' %>">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Settings</span>
          </a>
        </nav>

        <div class="px-4 py-4 border-t border-slate-200 dark:border-slate-800">
          <!-- Theme Toggle -->
          <button data-action="click->theme#toggle" class="w-full flex items-center gap-2 px-3 py-2 mb-3 text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 bg-slate-100 dark:bg-slate-800/50 rounded-lg transition-colors" title="Toggle theme">
            <span data-theme-target="icon">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            </span>
            <span>Toggle theme</span>
          </button>

          <% if current_user&.account %>
            <div class="text-xs font-medium text-slate-700 dark:text-slate-300 mb-0.5"><%= current_user.account.name %></div>
            <div class="text-xs text-slate-500 mb-2">
              <span class="inline-flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full <%= current_user.account.subscription_status == 'active' ? 'bg-emerald-400' : current_user.account.subscription_status == 'trialing' ? 'bg-cyan-400' : 'bg-amber-400' %>"></span>
                <%= current_user.account.plan.capitalize %> · <%= current_user.account.subscription_status.capitalize %>
              </span>
            </div>
          <% end %>
          <div class="text-xs text-slate-500 mb-2"><%= current_user&.email %></div>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-xs text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300" %>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-auto bg-slate-50 dark:bg-slate-900 transition-colors duration-200">
        <% if notice.present? %>
          <div class="mx-8 mt-6 p-4 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30 rounded-xl text-emerald-700 dark:text-emerald-400 text-sm font-medium flex items-center justify-between" data-controller="notification" data-notification-delay-value="5000">
            <span><%= notice %></span>
            <button data-action="click->notification#dismiss" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 ml-4">&times;</button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-8 mt-6 p-4 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 rounded-xl text-red-700 dark:text-red-400 text-sm font-medium flex items-center justify-between" data-controller="notification" data-notification-delay-value="8000">
            <span><%= alert %></span>
            <button data-action="click->notification#dismiss" class="text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 ml-4">&times;</button>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
