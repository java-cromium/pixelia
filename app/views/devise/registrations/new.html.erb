<div class="min-h-screen bg-brand-bg flex items-center justify-center px-6 py-12 relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-20 right-1/4 w-96 h-96 bg-brand-highlight/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-1/3 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
  </div>
  <div class="relative w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-16 w-auto mx-auto" %></a>
      <h2 class="mt-4 text-2xl font-bold text-brand-text">Create your account</h2>
      <p class="mt-2 text-sm text-brand-text-light">Start your 14-day free trial. No credit card required.</p>
    </div>

    <div class="bg-brand-card rounded-2xl border border-brand-border p-8 shadow-xl shadow-brand-border/30">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-5">
          <div>
            <%= f.label :company_name, "Company / Brand Name", class: "block text-sm font-semibold text-brand-text-muted mb-2" %>
            <%= f.text_field :company_name, autofocus: true, autocomplete: "organization", placeholder: "Acme Corp", class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt border border-brand-border text-brand-text placeholder-brand-text-light focus:ring-2 focus:ring-brand-highlight/30 focus:border-brand-highlight outline-none transition-shadow" %>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-semibold text-brand-text-muted mb-2" %>
            <%= f.email_field :email, autocomplete: "email", placeholder: "you@company.com", class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt border border-brand-border text-brand-text placeholder-brand-text-light focus:ring-2 focus:ring-brand-highlight/30 focus:border-brand-highlight outline-none transition-shadow" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-semibold text-brand-text-muted mb-2" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-brand-text-light mb-1"><%= @minimum_password_length %> characters minimum</p>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••", class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt border border-brand-border text-brand-text placeholder-brand-text-light focus:ring-2 focus:ring-brand-highlight/30 focus:border-brand-highlight outline-none transition-shadow" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-sm font-semibold text-brand-text-muted mb-2" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••", class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt border border-brand-border text-brand-text placeholder-brand-text-light focus:ring-2 focus:ring-brand-highlight/30 focus:border-brand-highlight outline-none transition-shadow" %>
          </div>

          <div class="pt-2">
            <%= f.submit "Start free trial", class: "w-full px-8 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover hover:shadow-xl hover:shadow-brand-highlight/30 transition-all duration-200 cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
