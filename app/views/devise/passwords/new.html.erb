<div class="min-h-screen bg-slate-900 flex items-center justify-center px-6 py-12 relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-1/3 left-1/4 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
  </div>
  <div class="relative w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-16 w-auto mx-auto" %></a>
      <h2 class="mt-4 text-2xl font-bold text-slate-50">Forgot your password?</h2>
      <p class="mt-2 text-slate-400 text-sm">Enter your email and we'll send you reset instructions.</p>
    </div>

    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 backdrop-blur-sm">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-5">
          <div>
            <%= f.label :email, class: "block text-sm font-semibold text-slate-300 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@company.com", class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
          </div>

          <div class="pt-2">
            <%= f.submit "Send reset instructions", class: "w-full px-8 py-3 bg-indigo-600 text-slate-50 font-semibold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 hover:shadow-xl hover:shadow-indigo-500/30 transition-all duration-200 cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
