<div class="min-h-screen bg-slate-900 flex items-center justify-center px-6 py-12 relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
  </div>
  <div class="relative w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-16 w-auto mx-auto" %></a>
      <h2 class="mt-4 text-2xl font-bold text-slate-50">Sign in to your account</h2>
    </div>

    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 backdrop-blur-sm">
      <% if notice.present? %>
        <div class="mb-6 p-4 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-400 text-sm font-medium"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-sm font-medium"><%= alert %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-5">
          <div>
            <%= f.label :email, class: "block text-sm font-semibold text-slate-300 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@company.com", class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-semibold text-slate-300 mb-2" %>
            <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-slate-700 bg-slate-900 text-indigo-600 focus:ring-indigo-500" %>
              <%= f.label :remember_me, class: "text-sm text-slate-400" %>
            </div>
          <% end %>

          <div class="pt-2">
            <%= f.submit "Sign in", class: "w-full px-8 py-3 bg-indigo-600 text-slate-50 font-semibold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 hover:shadow-xl hover:shadow-indigo-500/30 transition-all duration-200 cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
