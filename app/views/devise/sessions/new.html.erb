<div class="min-h-screen bg-brand-bg flex items-center justify-center px-6 py-12 relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-brand-highlight/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
  </div>
  <div class="relative w-full max-w-md">
    <div class="text-center mb-8">
      <a href="/"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-16 w-auto mx-auto" %></a>
      <h2 class="mt-4 text-2xl font-bold text-brand-text">Sign in to your account</h2>
    </div>

    <div class="bg-brand-card rounded-2xl border border-brand-border p-8 shadow-xl shadow-brand-border/30">
      <% if notice.present? %>
        <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm font-medium"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm font-medium"><%= alert %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-5">
          <div>
            <%= f.label :email, class: "block text-sm font-semibold text-brand-text-muted mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@company.com", class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt border border-brand-border text-brand-text placeholder-brand-text-light focus:ring-2 focus:ring-brand-highlight/30 focus:border-brand-highlight outline-none transition-shadow" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-semibold text-brand-text-muted mb-2" %>
            <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt border border-brand-border text-brand-text placeholder-brand-text-light focus:ring-2 focus:ring-brand-highlight/30 focus:border-brand-highlight outline-none transition-shadow" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-brand-border bg-brand-card text-brand-highlight focus:ring-brand-highlight" %>
              <%= f.label :remember_me, class: "text-sm text-brand-text-light" %>
            </div>
          <% end %>

          <div class="pt-2">
            <%= f.submit "Sign in", class: "w-full px-8 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover hover:shadow-xl hover:shadow-brand-highlight/30 transition-all duration-200 cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
