<% content_for(:title) { "Admin Dashboard — Pixelia" } %>

<div class="p-8">
  <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50 mb-8">Admin Dashboard</h1>

  <!-- Stats -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6 mb-12">
    <a href="<%= admin_accounts_path %>" class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6 hover:border-brand-highlight/40 dark:hover:border-indigo-500/40 hover:bg-brand-card-alt dark:hover:bg-slate-800 transition-all">
      <p class="text-sm font-medium text-brand-text-light dark:text-slate-400">Accounts</p>
      <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50"><%= @accounts_count %></p>
    </a>
    <a href="<%= admin_users_path %>" class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6 hover:border-brand-highlight/40 dark:hover:border-indigo-500/40 hover:bg-brand-card-alt dark:hover:bg-slate-800 transition-all">
      <p class="text-sm font-medium text-brand-text-light dark:text-slate-400">Users</p>
      <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50"><%= @users_count %></p>
    </a>
    <a href="<%= admin_sites_path %>" class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6 hover:border-brand-highlight/40 dark:hover:border-indigo-500/40 hover:bg-brand-card-alt dark:hover:bg-slate-800 transition-all">
      <p class="text-sm font-medium text-brand-text-light dark:text-slate-400">Sites</p>
      <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50"><%= @sites_count %></p>
    </a>
    <a href="<%= admin_leads_path %>" class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6 hover:border-brand-highlight/40 dark:hover:border-cyan-500/40 hover:bg-brand-card-alt dark:hover:bg-slate-800 transition-all">
      <p class="text-sm font-medium text-brand-text-light dark:text-slate-400">Leads</p>
      <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50"><%= @leads_count %></p>
    </a>
    <a href="<%= admin_ecommerce_stores_path %>" class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6 hover:border-brand-highlight/40 dark:hover:border-cyan-500/40 hover:bg-brand-card-alt dark:hover:bg-slate-800 transition-all">
      <p class="text-sm font-medium text-brand-text-light dark:text-slate-400">E-Commerce Stores</p>
      <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50"><%= @stores_count %></p>
    </a>
  </div>

  <!-- Charts -->
  <div class="grid lg:grid-cols-2 gap-8 mb-12">
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-4">Leads Over Time</h2>
      <%= line_chart @leads_by_month, colors: ["#4f46e5"], library: { plugins: { legend: { display: false } }, scales: { x: { ticks: { color: "#94a3b8" }, grid: { color: "#1e293b" } }, y: { ticks: { color: "#94a3b8" }, grid: { color: "#1e293b" } } } } %>
    </div>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-4">User Signups</h2>
      <%= area_chart @users_by_month, colors: ["#06b6d4"], library: { plugins: { legend: { display: false } }, scales: { x: { ticks: { color: "#94a3b8" }, grid: { color: "#1e293b" } }, y: { ticks: { color: "#94a3b8" }, grid: { color: "#1e293b" } } } } %>
    </div>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-4">Leads by Project Type</h2>
      <%= pie_chart @leads_by_type, colors: ["#4f46e5", "#06b6d4", "#8b5cf6", "#f59e0b", "#10b981", "#ef4444"], donut: true, library: { plugins: { legend: { labels: { color: "#94a3b8" } } } } %>
    </div>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-4">Stores by Platform</h2>
      <%= pie_chart @stores_by_platform, colors: ["#06b6d4", "#8b5cf6", "#10b981"], donut: true, library: { plugins: { legend: { labels: { color: "#94a3b8" } } } } %>
    </div>
  </div>

  <!-- Recent Leads -->
  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50">Recent Leads</h2>
      <a href="<%= admin_leads_path %>" class="text-sm font-medium text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300">View all &rarr;</a>
    </div>
    <% if @recent_leads.any? %>
      <table class="w-full">
        <thead>
          <tr class="text-left text-xs font-medium text-brand-text-muted dark:text-slate-500 uppercase tracking-wider border-b border-brand-border dark:border-slate-700">
            <th class="pb-3">Name</th>
            <th class="pb-3">Email</th>
            <th class="pb-3">Project Type</th>
            <th class="pb-3">Status</th>
            <th class="pb-3">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-brand-border dark:divide-slate-700/50">
          <% @recent_leads.each do |lead| %>
            <tr class="hover:bg-brand-card-alt dark:hover:bg-slate-700/30">
              <td class="py-3 font-medium text-brand-text dark:text-slate-50"><%= lead.first_name %></td>
              <td class="py-3 text-brand-text-light dark:text-slate-400"><%= lead.email %></td>
              <td class="py-3 text-brand-text-light dark:text-slate-400"><%= lead.project_type %></td>
              <td class="py-3">
                <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= lead.status == 'new' ? 'bg-brand-highlight/15 text-brand-highlight dark:bg-cyan-500/15 dark:text-cyan-400' : 'bg-brand-card-alt text-brand-text-muted dark:bg-slate-700 dark:text-slate-400' %>">
                  <%= lead.status&.capitalize %>
                </span>
              </td>
              <td class="py-3 text-sm text-brand-text-muted dark:text-slate-500"><%= lead.created_at.strftime("%b %d, %Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-brand-text-muted dark:text-slate-500 text-sm">No leads yet.</p>
    <% end %>
  </div>
</div>
