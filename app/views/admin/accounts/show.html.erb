<% content_for(:title) { "#{@account.name} — Admin — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= admin_accounts_path %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">&larr; Back to Accounts</a>
  </div>

  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-50"><%= @account.name %></h1>
      <p class="mt-1 text-slate-400"><%= @account.industry %></p>
    </div>
    <div class="flex gap-3">
      <a href="<%= edit_admin_account_path(@account) %>" class="px-5 py-2.5 bg-slate-800 border border-slate-700 text-sm font-semibold text-slate-300 rounded-xl hover:bg-slate-700 transition-colors">Edit</a>
      <%= button_to "Delete", admin_account_path(@account), method: :delete, data: { turbo_confirm: "Delete #{@account.name} and all associated data?" }, class: "px-5 py-2.5 bg-red-500/10 border border-red-500/30 text-sm font-semibold text-red-400 rounded-xl hover:bg-red-500/20 transition-colors cursor-pointer" %>
    </div>
  </div>

  <!-- Subscription Info -->
  <div class="grid sm:grid-cols-4 gap-6 mb-8">
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Plan</p>
      <p class="mt-2 text-lg font-bold text-slate-50"><%= @account.plan.capitalize %></p>
    </div>
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Status</p>
      <p class="mt-2 text-lg font-bold <%= subscription_status_class(@account.subscription_status) %>"><%= @account.subscription_status.capitalize %></p>
    </div>
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Trial Ends</p>
      <p class="mt-2 text-lg font-bold text-slate-50"><%= @account.trial_ends_at&.strftime("%b %d, %Y") || "—" %></p>
    </div>
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Stripe ID</p>
      <p class="mt-2 text-sm font-mono text-slate-400"><%= @account.stripe_customer_id.presence || "Not connected" %></p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-8">
    <!-- Users -->
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <h2 class="text-lg font-bold text-slate-50 mb-4">Users (<%= @users.count %>)</h2>
      <% if @users.any? %>
        <div class="divide-y divide-slate-700/50">
          <% @users.each do |user| %>
            <div class="py-3 flex items-center justify-between">
              <div>
                <p class="font-medium text-slate-50"><%= user.email %></p>
                <p class="text-xs text-slate-500"><%= user.role.humanize %></p>
              </div>
              <a href="<%= admin_user_path(user) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">View</a>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500">No users assigned to this account.</p>
      <% end %>
    </div>

    <!-- E-Commerce Stores -->
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <h2 class="text-lg font-bold text-slate-50 mb-4">Stores (<%= @stores.count %>)</h2>
      <% if @stores.any? %>
        <div class="divide-y divide-slate-700/50">
          <% @stores.each do |store| %>
            <div class="py-3 flex items-center justify-between">
              <div>
                <p class="font-medium text-slate-50"><%= store.platform.capitalize %></p>
                <p class="text-xs text-slate-500"><%= store.store_url %></p>
              </div>
              <a href="<%= admin_ecommerce_store_path(store) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">View</a>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500">No stores for this account.</p>
      <% end %>
    </div>
  </div>
</div>
