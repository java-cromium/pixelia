<%= form_with model: [:admin, account], class: "space-y-6" do |f| %>
  <% if account.errors.any? %>
    <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
      <ul class="list-disc list-inside text-sm text-red-500 dark:text-red-400 space-y-1">
        <% account.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.text_field :name, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow", placeholder: "Company Name" %>
  </div>

  <div>
    <%= f.label :industry, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.text_field :industry, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow", placeholder: "e.g. E-Commerce, Fashion, Tech" %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.select :status, options_for_select(["active", "inactive", "onboarding"], account.status), {}, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow" %>
  </div>

  <div class="pt-2">
    <%= f.submit class: "px-8 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all duration-200 cursor-pointer" %>
  </div>
<% end %>
