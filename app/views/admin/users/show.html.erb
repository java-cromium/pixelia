<% content_for(:title) { "#{@user.email} — Admin — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= admin_users_path %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">&larr; Back to Users</a>
  </div>

  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-50"><%= @user.email %></h1>
      <div class="mt-2 flex items-center gap-3">
        <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= @user.super_admin? ? 'bg-indigo-500/15 text-indigo-400' : 'bg-cyan-500/15 text-cyan-400' %>">
          <%= @user.role.humanize %>
        </span>
        <% if @user.account %>
          <span class="text-sm text-slate-400">Account: <a href="<%= admin_account_path(@user.account) %>" class="text-cyan-400 hover:text-cyan-300 font-medium"><%= @user.account.name %></a></span>
        <% end %>
      </div>
    </div>
    <div class="flex gap-3">
      <a href="<%= edit_admin_user_path(@user) %>" class="px-5 py-2.5 bg-slate-800 border border-slate-700 text-sm font-semibold text-slate-300 rounded-xl hover:bg-slate-700 transition-colors">Edit</a>
      <% unless @user == current_user %>
        <%= button_to "Delete", admin_user_path(@user), method: :delete, data: { turbo_confirm: "Delete user #{@user.email}?" }, class: "px-5 py-2.5 bg-red-500/10 border border-red-500/30 text-sm font-semibold text-red-400 rounded-xl hover:bg-red-500/20 transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 max-w-xl">
    <dl class="space-y-4">
      <div class="flex justify-between">
        <dt class="text-sm font-medium text-slate-500">Email</dt>
        <dd class="text-sm text-slate-50"><%= @user.email %></dd>
      </div>
      <div class="flex justify-between border-t border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-slate-500">Role</dt>
        <dd class="text-sm text-slate-50"><%= @user.role.humanize %></dd>
      </div>
      <div class="flex justify-between border-t border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-slate-500">Account</dt>
        <dd class="text-sm text-slate-50"><%= @user.account&.name || "None (Super Admin)" %></dd>
      </div>
      <div class="flex justify-between border-t border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-slate-500">Created</dt>
        <dd class="text-sm text-slate-50"><%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
      </div>
    </dl>
  </div>
</div>
