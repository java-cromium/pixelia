<% content_for(:title) { "Users — Admin — Pixelia" } %>

<div class="p-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-slate-50">Users</h1>
    <a href="<%= new_admin_user_path %>" class="px-5 py-2.5 bg-indigo-600 text-slate-50 text-sm font-semibold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-500 transition-colors">+ New User</a>
  </div>

  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 overflow-hidden" data-controller="search filter">
    <div class="px-6 py-4 border-b border-slate-700/50 flex items-center gap-4">
      <input type="text" placeholder="Search users..." data-search-target="input" data-action="input->search#filter" class="flex-1 px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
      <select data-filter-target="select" data-action="change->filter#apply" class="px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-slate-50 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
        <option value="all">All Roles</option>
        <option value="super_admin">Super Admin</option>
        <option value="client_user">Client User</option>
      </select>
    </div>
    <table class="w-full">
      <thead>
        <tr class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider bg-slate-800 border-b border-slate-700">
          <th class="px-6 py-3">Email</th>
          <th class="px-6 py-3">Role</th>
          <th class="px-6 py-3">Client</th>
          <th class="px-6 py-3">Created</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-700/50" data-search-target="body" data-filter-target="body">
        <% @users.each do |user| %>
          <tr class="hover:bg-slate-700/30 transition-colors" data-filter-value="<%= user.role %>">
            <td class="px-6 py-4 font-medium text-slate-50"><%= user.email %></td>
            <td class="px-6 py-4">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= user.super_admin? ? 'bg-indigo-500/15 text-indigo-400' : 'bg-cyan-500/15 text-cyan-400' %>">
                <%= user.role.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 text-slate-400"><%= user.client&.name || "—" %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= user.created_at.strftime("%b %d, %Y") %></td>
            <td class="px-6 py-4 text-right space-x-3">
              <a href="<%= admin_user_path(user) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">View</a>
              <a href="<%= edit_admin_user_path(user) %>" class="text-sm text-slate-400 hover:text-slate-300 font-medium">Edit</a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "shared/pagination" %>
</div>
