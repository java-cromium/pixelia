<%= form_with model: [:admin, user], class: "space-y-6" do |f| %>
  <% if user.errors.any? %>
    <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
      <ul class="list-disc list-inside text-sm text-red-500 dark:text-red-400 space-y-1">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :email, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.email_field :email, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow", placeholder: "user@company.com" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-1" %>
    <% if user.persisted? %>
      <p class="text-xs text-brand-text-muted dark:text-slate-500 mb-2">Leave blank to keep current password</p>
    <% end %>
    <%= f.password_field :password, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow", placeholder: "••••••••", autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.password_field :password_confirmation, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow", placeholder: "••••••••", autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.label :role, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.select :role, options_for_select(User.roles.keys.map { |r| [r.humanize, r] }, user.role), {}, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow" %>
  </div>

  <div>
    <%= f.label :account_id, "Account", class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.select :account_id, options_for_select(Account.order(:name).pluck(:name, :id), user.account_id), { include_blank: "None (Super Admin)" }, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow" %>
  </div>

  <div class="pt-2">
    <%= f.submit class: "px-8 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all duration-200 cursor-pointer" %>
  </div>
<% end %>
