<% content_for(:title) { "Lead: #{@lead.first_name} — Admin — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= admin_leads_path %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">&larr; Back to Leads</a>
  </div>

  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-50"><%= @lead.first_name %></h1>
      <p class="mt-1 text-slate-400"><%= @lead.email %></p>
    </div>
    <%= button_to "Delete", admin_lead_path(@lead), method: :delete, data: { turbo_confirm: "Delete this lead?" }, class: "px-5 py-2.5 bg-red-500/10 border border-red-500/30 text-sm font-semibold text-red-400 rounded-xl hover:bg-red-500/20 transition-colors cursor-pointer" %>
  </div>

  <div class="grid lg:grid-cols-2 gap-8">
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-slate-50 mb-6">Lead Details</h2>
      <dl class="space-y-4">
        <div class="flex justify-between">
          <dt class="text-sm font-medium text-slate-500">Name</dt>
          <dd class="text-sm text-slate-50"><%= @lead.first_name %></dd>
        </div>
        <div class="flex justify-between border-t border-slate-700/50 pt-4">
          <dt class="text-sm font-medium text-slate-500">Email</dt>
          <dd class="text-sm text-slate-50"><%= @lead.email %></dd>
        </div>
        <div class="flex justify-between border-t border-slate-700/50 pt-4">
          <dt class="text-sm font-medium text-slate-500">Project Type</dt>
          <dd class="text-sm text-slate-50"><%= @lead.project_type %></dd>
        </div>
        <div class="flex justify-between border-t border-slate-700/50 pt-4">
          <dt class="text-sm font-medium text-slate-500">Submitted</dt>
          <dd class="text-sm text-slate-50"><%= @lead.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-slate-50 mb-6">Update Status</h2>
      <%= form_with model: [:admin, @lead], class: "space-y-4" do |f| %>
        <div>
          <%= f.label :status, class: "block text-sm font-semibold text-slate-300 mb-2" %>
          <%= f.select :status, options_for_select(["new", "contacted", "converted", "disqualified"], @lead.status), {}, class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
        </div>
        <div>
          <%= f.submit "Update Status", class: "px-6 py-2.5 bg-indigo-600 text-slate-50 text-sm font-semibold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
