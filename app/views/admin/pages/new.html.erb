<% content_for(:title) { "New Page — #{@site.name} — Admin — Pixelia" } %>

<div class="p-8 max-w-2xl">
  <a href="<%= admin_site_path(@site) %>" class="text-sm text-slate-500 hover:text-cyan-400 transition-colors mb-4 inline-block">&larr; Back to <%= @site.name %></a>
  <h1 class="text-3xl font-bold text-slate-50 mb-8">New Page</h1>

  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8">
    <%= form_with(model: [:admin, @site, @page]) do |form| %>
      <%= render "form", form: form, page: @page %>
      <div class="mt-8">
        <%= form.submit "Create Page", class: "px-6 py-2.5 bg-indigo-600 text-slate-50 text-sm font-semibold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-500 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
