<%= form_with model: [:admin, store], class: "space-y-6" do |f| %>
  <% if store.errors.any? %>
    <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
      <ul class="list-disc list-inside text-sm text-red-500 dark:text-red-400 space-y-1">
        <% store.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :platform, class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.select :platform, options_for_select(EcommerceStore::PLATFORMS.map { |p| [p.capitalize, p] }, store.platform), { include_blank: "Select platform..." }, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow" %>
  </div>

  <div>
    <%= f.label :store_url, "Store URL", class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.url_field :store_url, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow", placeholder: "https://mystore.myshopify.com" %>
  </div>

  <div>
    <%= f.label :account_id, "Account", class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
    <%= f.select :account_id, options_for_select(Account.order(:name).pluck(:name, :id), store.account_id), { include_blank: "Select account..." }, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow" %>
  </div>

  <div class="border-t border-brand-border dark:border-slate-700/50 pt-6">
    <h3 class="text-sm font-bold text-brand-text dark:text-slate-50 mb-1">API Credentials</h3>
    <p class="text-xs text-brand-text-muted dark:text-slate-500 mb-4">Credentials are encrypted at rest using Active Record Encryption.</p>

    <div class="space-y-4">
      <div>
        <%= f.label :api_key, "API Key / Access Token", class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
        <%= f.text_field :api_key, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow font-mono text-sm", placeholder: store.persisted? ? "Leave blank to keep current" : "shpat_xxxxxxxxxxxxx", autocomplete: "off" %>
      </div>

      <div>
        <%= f.label :api_secret, "API Secret / Consumer Secret", class: "block text-sm font-semibold text-brand-text-light dark:text-slate-300 mb-2" %>
        <%= f.text_field :api_secret, class: "w-full px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-brand-text-muted dark:placeholder-slate-500 focus:ring-2 focus:ring-brand-highlight focus:border-brand-highlight outline-none transition-shadow font-mono text-sm", placeholder: store.persisted? ? "Leave blank to keep current" : "cs_xxxxxxxxxxxxx", autocomplete: "off" %>
      </div>
    </div>
  </div>

  <div class="pt-2">
    <%= f.submit class: "px-8 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all duration-200 cursor-pointer" %>
  </div>
<% end %>
