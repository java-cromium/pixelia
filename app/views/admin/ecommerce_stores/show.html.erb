<% content_for(:title) { "#{@store.platform.capitalize} Store — Admin — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= admin_ecommerce_stores_path %>" class="text-sm text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300 font-medium">&larr; Back to Stores</a>
  </div>

  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50"><%= @store.platform.capitalize %> Store</h1>
      <p class="mt-1 text-brand-text-light dark:text-slate-400"><%= @store.store_url %></p>
    </div>
    <div class="flex gap-3">
      <a href="<%= edit_admin_ecommerce_store_path(@store) %>" class="px-5 py-2.5 bg-brand-card-alt dark:bg-slate-800 border border-brand-border dark:border-slate-700 text-sm font-semibold text-brand-text-light dark:text-slate-300 rounded-xl hover:bg-brand-card dark:hover:bg-slate-700 transition-colors">Edit</a>
      <%= button_to "Delete", admin_ecommerce_store_path(@store), method: :delete, data: { turbo_confirm: "Delete this store?" }, class: "px-5 py-2.5 bg-red-500/10 border border-red-500/30 text-sm font-semibold text-red-500 dark:text-red-400 rounded-xl hover:bg-red-500/20 transition-colors cursor-pointer" %>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6">
      <p class="text-xs font-medium text-brand-text-muted dark:text-slate-500 uppercase tracking-wider">Platform</p>
      <p class="mt-2 text-lg font-bold text-brand-text dark:text-slate-50"><%= @store.platform.capitalize %></p>
    </div>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6">
      <p class="text-xs font-medium text-brand-text-muted dark:text-slate-500 uppercase tracking-wider">Connection</p>
      <p class="mt-2">
        <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= @store.connected? ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400' : 'bg-amber-500/15 text-amber-600 dark:text-amber-400' %>">
          <%= @store.connected? ? "Connected" : "Keys Missing" %>
        </span>
      </p>
    </div>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6">
      <p class="text-xs font-medium text-brand-text-muted dark:text-slate-500 uppercase tracking-wider">Account</p>
      <p class="mt-2 text-lg font-bold text-brand-text dark:text-slate-50">
        <a href="<%= admin_account_path(@store.account) %>" class="text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300"><%= @store.account.name %></a>
      </p>
    </div>
  </div>

  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
    <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">API Credentials</h2>
    <p class="text-xs text-brand-text-muted dark:text-slate-500 mb-4">Keys are encrypted at rest. Only masked values are shown.</p>
    <dl class="space-y-4">
      <div class="flex items-center justify-between">
        <dt class="text-sm font-medium text-brand-text-muted dark:text-slate-500">Store URL</dt>
        <dd class="text-sm text-brand-text dark:text-slate-50 font-mono"><%= @store.store_url %></dd>
      </div>
      <div class="flex items-center justify-between border-t border-brand-border dark:border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-brand-text-muted dark:text-slate-500">API Key</dt>
        <dd class="text-sm text-brand-text dark:text-slate-50 font-mono"><%= @store.masked_api_key %></dd>
      </div>
      <div class="flex items-center justify-between border-t border-brand-border dark:border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-brand-text-muted dark:text-slate-500">API Secret</dt>
        <dd class="text-sm text-brand-text dark:text-slate-50 font-mono"><%= @store.masked_api_secret %></dd>
      </div>
    </dl>
  </div>
</div>
