<% content_for(:title) { "New Site — Admin — Pixelia" } %>

<div class="p-8 max-w-2xl">
  <a href="<%= admin_sites_path %>" class="text-sm text-brand-text-muted dark:text-slate-500 hover:text-brand-highlight dark:hover:text-cyan-400 transition-colors mb-4 inline-block">&larr; Back to Sites</a>
  <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50 mb-8">New Site</h1>

  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
    <%= form_with(model: [:admin, @site]) do |form| %>
      <%= render "form", form: form, site: @site %>
      <div class="mt-8">
        <%= form.submit "Create Site", class: "px-6 py-2.5 bg-brand-highlight text-white text-sm font-semibold rounded-xl shadow-lg shadow-brand-highlight/20 hover:bg-brand-highlight-hover transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
