<% content_for(:title) { "Sites — Admin — Pixelia" } %>

<div class="p-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50">Sites</h1>
    <a href="<%= new_admin_site_path %>" class="px-5 py-2.5 bg-brand-highlight text-white text-sm font-semibold rounded-xl shadow-lg shadow-brand-highlight/20 hover:bg-brand-highlight-hover transition-colors">+ New Site</a>
  </div>

  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="text-left text-xs font-medium text-brand-text-muted dark:text-slate-500 uppercase tracking-wider bg-brand-card-alt dark:bg-slate-800 border-b border-brand-border dark:border-slate-700">
          <th class="px-6 py-3">Name</th>
          <th class="px-6 py-3">Account</th>
          <th class="px-6 py-3">Domain</th>
          <th class="px-6 py-3">Pages</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-brand-border dark:divide-slate-700/50">
        <% @sites.each do |site| %>
          <tr class="hover:bg-brand-card-alt dark:hover:bg-slate-700/30 transition-colors">
            <td class="px-6 py-4 font-medium text-brand-text dark:text-slate-50"><%= site.name %></td>
            <td class="px-6 py-4 text-brand-text-light dark:text-slate-400"><%= site.account.name %></td>
            <td class="px-6 py-4 text-brand-text-light dark:text-slate-400 text-sm font-mono"><%= site.domain_display || "—" %></td>
            <td class="px-6 py-4 text-brand-text-light dark:text-slate-400"><%= site.pages.size %></td>
            <td class="px-6 py-4">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= site.published? ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400' : 'bg-amber-500/15 text-amber-600 dark:text-amber-400' %>">
                <%= site.published? ? "Published" : "Draft" %>
              </span>
            </td>
            <td class="px-6 py-4 text-right space-x-3">
              <a href="<%= admin_site_path(site) %>" class="text-sm text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300 font-medium">View</a>
              <a href="<%= edit_admin_site_path(site) %>" class="text-sm text-brand-text-muted dark:text-slate-400 hover:text-brand-text-light dark:hover:text-slate-300 font-medium">Edit</a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "shared/pagination" %>
</div>
