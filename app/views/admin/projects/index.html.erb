<% content_for(:title) { "Projects — Admin — Pixelia" } %>

<div class="p-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-slate-50">Projects</h1>
    <a href="<%= new_admin_project_path %>" class="px-5 py-2.5 bg-indigo-600 text-slate-50 text-sm font-semibold rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-500 transition-colors">+ New Project</a>
  </div>

  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider bg-slate-800 border-b border-slate-700">
          <th class="px-6 py-3">Name</th>
          <th class="px-6 py-3">Client</th>
          <th class="px-6 py-3">Type</th>
          <th class="px-6 py-3">Status</th>
          <th class="px-6 py-3">Launch Date</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-700/50">
        <% @projects.each do |project| %>
          <tr class="hover:bg-slate-700/30 transition-colors">
            <td class="px-6 py-4 font-medium text-slate-50"><%= project.name %></td>
            <td class="px-6 py-4 text-slate-400"><%= project.client.name %></td>
            <td class="px-6 py-4 text-slate-400"><%= project.project_type %></td>
            <td class="px-6 py-4">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full
                <%= case project.status
                    when 'active' then 'bg-emerald-500/15 text-emerald-400'
                    when 'in_progress' then 'bg-cyan-500/15 text-cyan-400'
                    else 'bg-slate-700 text-slate-400'
                    end %>">
                <%= project.status&.humanize %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= project.launch_date&.strftime("%b %d, %Y") || "TBD" %></td>
            <td class="px-6 py-4 text-right space-x-3">
              <a href="<%= admin_project_path(project) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">View</a>
              <a href="<%= edit_admin_project_path(project) %>" class="text-sm text-slate-400 hover:text-slate-300 font-medium">Edit</a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "shared/pagination" %>
</div>
