<%= form_with model: [:admin, project], class: "space-y-6" do |f| %>
  <% if project.errors.any? %>
    <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
      <ul class="list-disc list-inside text-sm text-red-400 space-y-1">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-semibold text-slate-300 mb-2" %>
    <%= f.text_field :name, class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow", placeholder: "Project Name" %>
  </div>

  <div>
    <%= f.label :client_id, "Client", class: "block text-sm font-semibold text-slate-300 mb-2" %>
    <%= f.select :client_id, options_for_select(Client.order(:name).pluck(:name, :id), project.client_id), { include_blank: "Select a client..." }, class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
  </div>

  <div>
    <%= f.label :project_type, class: "block text-sm font-semibold text-slate-300 mb-2" %>
    <%= f.select :project_type, options_for_select(["Website", "E-Commerce", "SEO", "Paid Advertising", "Social Media", "Full 360°"], project.project_type), { include_blank: "Select type..." }, class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-semibold text-slate-300 mb-2" %>
    <%= f.select :status, options_for_select(["active", "in_progress", "completed", "paused"], project.status), {}, class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
  </div>

  <div>
    <%= f.label :launch_date, class: "block text-sm font-semibold text-slate-300 mb-2" %>
    <%= f.date_field :launch_date, class: "w-full px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
  </div>

  <div class="pt-2">
    <%= f.submit class: "px-8 py-3 bg-indigo-600 text-slate-50 font-semibold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 transition-all duration-200 cursor-pointer" %>
  </div>
<% end %>
