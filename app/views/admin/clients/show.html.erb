<% content_for(:title) { "#{@client.name} — Admin — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= admin_clients_path %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">&larr; Back to Clients</a>
  </div>

  <div class="flex items-start justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-slate-50"><%= @client.name %></h1>
      <p class="mt-1 text-slate-400"><%= @client.industry %></p>
    </div>
    <div class="flex gap-3">
      <a href="<%= edit_admin_client_path(@client) %>" class="px-5 py-2.5 bg-slate-800 border border-slate-700 text-sm font-semibold text-slate-300 rounded-xl hover:bg-slate-700 transition-colors">Edit</a>
      <%= button_to "Delete", admin_client_path(@client), method: :delete, data: { turbo_confirm: "Delete #{@client.name} and all associated data?" }, class: "px-5 py-2.5 bg-red-500/10 border border-red-500/30 text-sm font-semibold text-red-400 rounded-xl hover:bg-red-500/20 transition-colors cursor-pointer" %>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-8">
    <!-- Users -->
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <h2 class="text-lg font-bold text-slate-50 mb-4">Users (<%= @users.count %>)</h2>
      <% if @users.any? %>
        <div class="divide-y divide-slate-700/50">
          <% @users.each do |user| %>
            <div class="py-3 flex items-center justify-between">
              <div>
                <p class="font-medium text-slate-50"><%= user.email %></p>
                <p class="text-xs text-slate-500"><%= user.role.humanize %></p>
              </div>
              <a href="<%= admin_user_path(user) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">View</a>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500">No users assigned to this client.</p>
      <% end %>
    </div>

    <!-- Projects -->
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6">
      <h2 class="text-lg font-bold text-slate-50 mb-4">Projects (<%= @projects.count %>)</h2>
      <% if @projects.any? %>
        <div class="divide-y divide-slate-700/50">
          <% @projects.each do |project| %>
            <div class="py-3 flex items-center justify-between">
              <div>
                <p class="font-medium text-slate-50"><%= project.name %></p>
                <p class="text-xs text-slate-500"><%= project.project_type %> · <%= project.status&.capitalize %></p>
              </div>
              <a href="<%= admin_project_path(project) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">View</a>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500">No projects for this client.</p>
      <% end %>
    </div>
  </div>
</div>
