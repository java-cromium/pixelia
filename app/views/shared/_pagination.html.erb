<% if @pagy && @pagy.pages > 1 %>
  <nav class="flex items-center justify-between mt-8 pt-6 border-t border-slate-700/50">
    <p class="text-sm text-slate-500">
      Mostrando <span class="font-medium text-slate-300"><%= @pagy.from %></span> a <span class="font-medium text-slate-300"><%= @pagy.to %></span> de <span class="font-medium text-slate-300"><%= @pagy.count %></span> resultados
    </p>
    <div class="flex items-center gap-1">
      <% if @pagy.prev %>
        <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "px-3 py-2 text-sm font-medium text-slate-400 hover:text-cyan-400 bg-slate-800/50 border border-slate-700/50 rounded-lg hover:border-cyan-500/30 transition-colors" do %>
          &larr;
        <% end %>
      <% end %>

      <% @pagy.series.each do |item| %>
        <% if item.is_a?(Integer) %>
          <%= link_to item, pagy_url_for(@pagy, item), class: "px-3 py-2 text-sm font-medium text-slate-400 hover:text-cyan-400 bg-slate-800/50 border border-slate-700/50 rounded-lg hover:border-cyan-500/30 transition-colors" %>
        <% elsif item.is_a?(String) %>
          <span class="px-3 py-2 text-sm font-semibold text-slate-50 bg-indigo-600 border border-indigo-500 rounded-lg shadow-sm shadow-indigo-600/25"><%= item %></span>
        <% elsif item == :gap %>
          <span class="px-2 py-2 text-sm text-slate-500">&hellip;</span>
        <% end %>
      <% end %>

      <% if @pagy.next %>
        <%= link_to pagy_url_for(@pagy, @pagy.next), class: "px-3 py-2 text-sm font-medium text-slate-400 hover:text-cyan-400 bg-slate-800/50 border border-slate-700/50 rounded-lg hover:border-cyan-500/30 transition-colors" do %>
          &rarr;
        <% end %>
      <% end %>
    </div>
  </nav>
<% end %>
