<% content_for(:title) { "E-Commerce Stores — Pixelia" } %>

<div class="min-h-screen bg-slate-900">
  <!-- Top Navigation -->
  <nav class="bg-slate-950 border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="<%= portal_root_path %>"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-12 w-auto" %></a>
        <span class="text-xs font-medium text-cyan-400 bg-cyan-500/10 px-2 py-1 rounded-full">Portal</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="<%= projects_path %>" class="text-sm font-medium text-slate-400 hover:text-cyan-400 transition-colors">Projects</a>
        <a href="<%= ecommerce_stores_path %>" class="text-sm font-semibold text-cyan-400">Stores</a>
        <% if current_user %>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-red-400 hover:text-red-300 transition-colors" %>
        <% end %>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-50">E-Commerce Stores</h1>
      <p class="mt-1 text-slate-400">Connected stores and their sync status.</p>
    </div>

    <% if @ecommerce_stores.any? %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @ecommerce_stores.each do |store| %>
          <a href="<%= ecommerce_store_path(store) %>" class="block bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6 hover:border-indigo-500/50 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-200">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-indigo-500/15 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-slate-50"><%= store.platform %></h3>
                <p class="text-xs text-slate-500"><%= store.store_url %></p>
              </div>
            </div>
            <div class="pt-4 border-t border-slate-700/50">
              <p class="text-xs text-slate-500">Project: <span class="font-medium text-slate-300"><%= store.project.name %></span></p>
            </div>
          </a>
        <% end %>
      </div>
    <% else %>
      <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-16 text-center">
        <div class="w-16 h-16 bg-indigo-500/15 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-50">No stores connected</h3>
        <p class="mt-2 text-slate-500 text-sm">E-commerce store integrations will appear here once configured.</p>
      </div>
    <% end %>
  </div>
</div>
