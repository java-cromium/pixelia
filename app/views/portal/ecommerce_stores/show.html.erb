<% content_for(:title) { "#{@ecommerce_store.platform} Store — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= portal_ecommerce_stores_path %>" class="text-sm text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300 font-medium">&larr; Back to Stores</a>
  </div>

    <!-- Store Header -->
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 mb-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14 bg-brand-highlight/15 rounded-xl flex items-center justify-center">
          <svg class="w-7 h-7 text-brand-highlight dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50"><%= @ecommerce_store.platform %></h1>
          <p class="text-brand-text-light dark:text-slate-400"><%= @ecommerce_store.store_url %></p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 pt-6 border-t border-brand-border dark:border-slate-700/50">
        <div>
          <p class="text-xs font-medium text-brand-text-light dark:text-slate-500 uppercase tracking-wider">Platform</p>
          <p class="mt-1 text-sm font-semibold text-brand-text dark:text-slate-50"><%= @ecommerce_store.platform %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-brand-text-light dark:text-slate-500 uppercase tracking-wider">API Status</p>
          <span class="mt-1 inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1 rounded-full
            <%= @ecommerce_store.api_key.present? ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400' : 'bg-amber-500/15 text-amber-600 dark:text-amber-400' %>">
            <span class="w-1.5 h-1.5 rounded-full <%= @ecommerce_store.api_key.present? ? 'bg-emerald-400' : 'bg-amber-400' %>"></span>
            <%= @ecommerce_store.api_key.present? ? "Connected" : "Keys Missing" %>
          </span>
        </div>
      </div>
    </div>

    <!-- Sales Dashboard Placeholder -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6">
        <p class="text-sm font-medium text-brand-text-light dark:text-slate-500">Total Revenue</p>
        <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50">—</p>
        <p class="mt-1 text-xs text-brand-text-light dark:text-slate-500">Sync pending</p>
      </div>
      <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6">
        <p class="text-sm font-medium text-brand-text-light dark:text-slate-500">Orders (30d)</p>
        <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50">—</p>
        <p class="mt-1 text-xs text-brand-text-light dark:text-slate-500">Sync pending</p>
      </div>
      <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6">
        <p class="text-sm font-medium text-brand-text-light dark:text-slate-500">Avg Order Value</p>
        <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50">—</p>
        <p class="mt-1 text-xs text-brand-text-light dark:text-slate-500">Sync pending</p>
      </div>
    </div>

    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 text-center">
      <p class="text-brand-text-light dark:text-slate-500 text-sm">Live sales data and product analytics will appear here once the store API is synced via Sidekiq.</p>
    </div>
</div>
