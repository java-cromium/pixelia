<div class="p-8 max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-brand-text dark:text-slate-50">AI Chat Support</h1>
      <p class="text-sm text-brand-text-light dark:text-slate-500 mt-1">Get instant help with your Pixelia account</p>
    </div>
    <%= link_to portal_chats_path, data: { turbo_method: :post }, class: "inline-flex items-center gap-2 px-4 py-2.5 bg-brand-highlight text-white text-sm font-semibold rounded-xl hover:bg-brand-highlight-hover transition-colors shadow-sm" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Conversation
    <% end %>
  </div>

  <% if @conversations.any? %>
    <div class="space-y-3">
      <% @conversations.each do |conversation| %>
        <%= link_to portal_chat_path(conversation), class: "block bg-brand-card dark:bg-slate-800/50 rounded-xl border border-brand-border dark:border-slate-700/50 p-5 hover:border-brand-highlight/50 dark:hover:border-cyan-600 transition-colors group" do %>
          <div class="flex items-center justify-between">
            <div>
              <h3 class="font-medium text-brand-text dark:text-slate-50 group-hover:text-brand-highlight dark:group-hover:text-cyan-400 transition-colors">
                <%= conversation.title %>
              </h3>
              <p class="text-xs text-brand-text-light dark:text-slate-500 mt-1">
                <%= conversation.chat_messages.count %> messages · Updated <%= time_ago_in_words(conversation.updated_at) %> ago
              </p>
            </div>
            <svg class="w-5 h-5 text-brand-text-light dark:text-slate-400 group-hover:text-brand-highlight dark:group-hover:text-cyan-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-12 text-center">
      <div class="w-16 h-16 mx-auto mb-4 bg-brand-highlight/10 rounded-2xl flex items-center justify-center">
        <svg class="w-8 h-8 text-brand-highlight dark:text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-brand-text dark:text-slate-50 mb-2">Start a conversation</h3>
      <p class="text-sm text-brand-text-light dark:text-slate-500 mb-6">Ask Pixelia AI about campaigns, billing, domains, or anything else.</p>
      <%= link_to portal_chats_path, data: { turbo_method: :post }, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-brand-highlight text-white font-semibold rounded-xl hover:bg-brand-highlight-hover transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        New Conversation
      <% end %>
    </div>
  <% end %>
</div>
