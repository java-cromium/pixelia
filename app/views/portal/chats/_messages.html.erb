<% messages.each do |message| %>
  <div class="flex <%= message.user? ? 'justify-end' : 'justify-start' %>">
    <div class="max-w-[80%] <%= message.user? ? 'bg-cyan-600 text-white' : 'bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-800 dark:text-slate-50' %> rounded-2xl px-4 py-3 shadow-sm">
      <% if message.assistant? %>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-5 h-5 bg-gradient-to-br from-cyan-400 to-blue-500 rounded-full flex items-center justify-center">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 01.894.553l1.789 3.578 3.953.576a1 1 0 01.554 1.706l-2.86 2.788.675 3.937a1 1 0 01-1.451 1.054L10 13.764l-3.554 1.428a1 1 0 01-1.451-1.054l.675-3.937-2.86-2.788a1 1 0 01.554-1.706l3.953-.576L9.106 2.553A1 1 0 0110 2z"/></svg>
          </span>
          <span class="text-xs font-medium text-slate-500 dark:text-slate-400">Pixelia AI</span>
        </div>
      <% end %>
      <div class="text-sm leading-relaxed whitespace-pre-wrap"><%= message.content %></div>
      <div class="text-[10px] mt-1.5 <%= message.user? ? 'text-cyan-200' : 'text-slate-400' %>">
        <%= message.created_at.strftime("%l:%M %p") %>
      </div>
    </div>
  </div>
<% end %>

<% if messages.empty? %>
  <div class="flex-1 flex items-center justify-center">
    <div class="text-center">
      <div class="w-12 h-12 mx-auto mb-3 bg-cyan-500/10 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
      </div>
      <p class="text-sm text-slate-500">Send a message to get started</p>
    </div>
  </div>
<% end %>
