<div class="flex flex-col h-[calc(100vh-2rem)] max-w-4xl mx-auto p-8" data-controller="chat">
  <!-- Header -->
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <%= link_to portal_chats_path, class: "text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <% end %>
      <div>
        <h1 class="text-lg font-bold text-slate-800 dark:text-slate-50"><%= @conversation.title %></h1>
        <p class="text-xs text-slate-500"><%= @conversation.chat_messages.count %> messages</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= button_to portal_chat_path(@conversation), method: :delete,
          class: "text-xs text-red-500 dark:text-red-400 hover:text-red-600 font-medium px-3 py-1.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-500/10 transition-colors",
          data: { turbo_confirm: "Archive this conversation?" } do %>
        Archive
      <% end %>
    </div>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="flex-1 overflow-y-auto space-y-4 mb-4 scroll-smooth" data-chat-target="messages">
    <%= render partial: "portal/chats/messages", locals: { messages: @messages } %>
  </div>

  <!-- Input -->
  <%= form_with url: message_portal_chat_path(@conversation), method: :post, class: "flex-shrink-0", data: { chat_target: "form", action: "submit->chat#send" } do |f| %>
    <div class="flex gap-3 items-end">
      <div class="flex-1 relative">
        <%= f.text_area :message,
          placeholder: "Ask Pixelia AI anything...",
          rows: 1,
          class: "w-full resize-none rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 text-slate-800 dark:text-slate-50 placeholder-slate-400 px-4 py-3 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-transparent transition-all",
          data: { chat_target: "input", action: "keydown->chat#handleKeydown input->chat#autoResize" } %>
      </div>
      <button type="submit" class="flex-shrink-0 w-10 h-10 bg-cyan-600 hover:bg-cyan-500 text-white rounded-xl flex items-center justify-center transition-colors disabled:opacity-50 disabled:cursor-not-allowed" data-chat-target="submit">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19V5m0 0l-7 7m7-7l7 7"/></svg>
      </button>
    </div>
  <% end %>
</div>
