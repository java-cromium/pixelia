<% content_for(:title) { "Meta Ads Campaigns — Pixelia" } %>

<div class="p-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50">Meta Ads Campaigns</h1>
      <p class="mt-1 text-brand-text-light dark:text-slate-400">Manage your Facebook & Instagram ad campaigns.</p>
    </div>
    <div class="flex items-center gap-3">
      <% if @meta_account&.connected? %>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-emerald-600 dark:text-emerald-400 bg-emerald-500/10 px-3 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
          Connected as <%= @meta_account.meta_email %>
        </span>
      <% end %>
      <a href="<%= new_portal_meta_campaign_path %>" class="px-5 py-2.5 bg-brand-highlight text-white text-sm font-semibold rounded-xl shadow-lg shadow-brand-highlight/20 hover:bg-brand-highlight-hover transition-colors">+ New Campaign</a>
    </div>
  </div>

  <% if @campaigns.any? %>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 overflow-hidden shadow-sm dark:shadow-none">
      <table class="w-full">
        <thead>
          <tr class="text-left text-xs font-medium text-brand-text-light dark:text-slate-500 uppercase tracking-wider bg-brand-card-alt dark:bg-slate-800 border-b border-brand-border dark:border-slate-700">
            <th class="px-6 py-3">Campaign</th>
            <th class="px-6 py-3">Objective</th>
            <th class="px-6 py-3">Status</th>
            <th class="px-6 py-3">Budget</th>
            <th class="px-6 py-3">Created</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-brand-border dark:divide-slate-700/50">
          <% @campaigns.each do |campaign| %>
            <tr class="hover:bg-brand-card-alt dark:hover:bg-slate-700/30 transition-colors">
              <td class="px-6 py-4">
                <a href="<%= portal_meta_campaign_path(campaign) %>" class="font-medium text-brand-text dark:text-slate-50 hover:text-brand-highlight dark:hover:text-cyan-400 transition-colors"><%= campaign.name %></a>
                <% if campaign.synced? %>
                  <p class="text-xs text-brand-text-light dark:text-slate-500 mt-0.5">ID: <%= campaign.meta_campaign_id %></p>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-brand-card-alt dark:bg-slate-700 text-brand-text-muted dark:text-slate-300"><%= campaign.objective_display %></span>
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center gap-1.5 text-xs font-medium <%= meta_campaign_status_class(campaign.status) %> px-2.5 py-1 rounded-full">
                  <span class="w-1.5 h-1.5 rounded-full <%= meta_campaign_status_dot(campaign.status) %>"></span>
                  <%= campaign.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-brand-text-muted dark:text-slate-300"><%= campaign.budget_display || "—" %></td>
              <td class="px-6 py-4 text-sm text-brand-text-light dark:text-slate-400"><%= campaign.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4 text-right">
                <a href="<%= portal_meta_campaign_path(campaign) %>" class="text-sm text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300 font-medium">View</a>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-16 text-center shadow-sm dark:shadow-none">
      <div class="w-16 h-16 bg-brand-highlight/15 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-brand-highlight dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M6.915 4.03c-1.968 0-3.762 1.085-4.907 2.895C.877 8.737.2 10.97.2 13.395c0 2.424.678 4.658 1.808 6.47 1.145 1.81 2.94 2.895 4.907 2.895 1.208 0 2.347-.377 3.312-1.084.735-.538 1.36-1.245 1.865-2.08.506.836 1.13 1.542 1.865 2.08.965.707 2.104 1.084 3.312 1.084 1.968 0 3.762-1.085 4.907-2.895 1.13-1.812 1.808-4.046 1.808-6.47 0-2.424-.678-4.658-1.808-6.47-1.145-1.81-2.94-2.895-4.907-2.895-1.208 0-2.347.377-3.312 1.084-.735.538-1.36 1.245-1.865 2.08-.506-.835-1.13-1.542-1.865-2.08-.965-.707-2.104-1.084-3.312-1.084zm0 2.1c.746 0 1.5.26 2.168.755.66.488 1.235 1.18 1.674 2.013.545 1.03.886 2.257.994 3.596H4.08c.108-1.34.449-2.566.994-3.596.44-.833 1.014-1.525 1.674-2.013.669-.496 1.422-.755 2.168-.755zm10.17 0c.746 0 1.5.26 2.168.755.66.488 1.235 1.18 1.674 2.013.545 1.03.886 2.257.994 3.596h-7.672c.108-1.34.449-2.566.994-3.596.44-.833 1.014-1.525 1.674-2.013.669-.496 1.422-.755 2.168-.755zM4.08 14.494h7.672c-.108 1.34-.449 2.566-.994 3.596-.44.833-1.014 1.525-1.674 2.013-.669.496-1.422.755-2.168.755-.746 0-1.5-.26-2.168-.755-.66-.488-1.235-1.18-1.674-2.013-.545-1.03-.886-2.257-.994-3.596zm9.92 0h7.672c-.108 1.34-.449 2.566-.994 3.596-.44.833-1.014 1.525-1.674 2.013-.669.496-1.422.755-2.168.755-.746 0-1.5-.26-2.168-.755-.66-.488-1.235-1.18-1.674-2.013-.545-1.03-.886-2.257-.994-3.596z"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-brand-text dark:text-slate-50">No campaigns yet</h3>
      <p class="mt-2 text-brand-text-light dark:text-slate-500 text-sm mb-6">Create your first Meta Ads campaign to reach audiences on Facebook & Instagram.</p>
      <a href="<%= new_portal_meta_campaign_path %>" class="inline-flex px-5 py-2.5 bg-brand-highlight text-white text-sm font-semibold rounded-xl shadow-lg shadow-brand-highlight/20 hover:bg-brand-highlight-hover transition-colors">+ Create First Campaign</a>
    </div>
  <% end %>
</div>
