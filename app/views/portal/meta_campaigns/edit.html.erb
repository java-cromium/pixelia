<% content_for(:title) { "Edit #{@campaign.name} — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= portal_meta_campaign_path(@campaign) %>" class="text-sm text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300 font-medium">&larr; Back to Campaign</a>
  </div>

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50">Edit Meta Campaign</h1>
    <p class="mt-2 text-brand-text-light dark:text-slate-400"><%= @campaign.name %></p>
  </div>

  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 max-w-3xl shadow-sm dark:shadow-none">
    <%= render "form", form_url: portal_meta_campaign_path(@campaign), submit_label: "Save Changes" %>
  </div>
</div>
