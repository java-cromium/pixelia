<% content_for(:title) { "Projects — Pixelia" } %>

<div class="min-h-screen bg-slate-900">
  <!-- Top Navigation -->
  <nav class="bg-slate-950 border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="<%= portal_root_path %>"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-12 w-auto" %></a>
        <span class="text-xs font-medium text-cyan-400 bg-cyan-500/10 px-2 py-1 rounded-full">Portal</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="<%= projects_path %>" class="text-sm font-semibold text-cyan-400">Projects</a>
        <a href="<%= ecommerce_stores_path %>" class="text-sm font-medium text-slate-400 hover:text-cyan-400 transition-colors">Stores</a>
        <% if current_user %>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-red-400 hover:text-red-300 transition-colors" %>
        <% end %>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-50">Projects</h1>
        <p class="mt-1 text-slate-400">All your web and marketing projects in one place.</p>
      </div>
    </div>

    <% if @projects.any? %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @projects.each do |project| %>
          <a href="<%= project_path(project) %>" class="block bg-slate-800/50 rounded-2xl border border-slate-700/50 p-6 hover:border-indigo-500/50 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-200">
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-lg font-bold text-slate-50"><%= project.name %></h3>
              <span class="text-xs font-medium px-3 py-1 rounded-full
                <%= project.status == 'active' ? 'bg-emerald-500/15 text-emerald-400' : 'bg-slate-700 text-slate-400' %>">
                <%= project.status&.capitalize || "N/A" %>
              </span>
            </div>
            <p class="text-sm text-slate-400 mb-4"><%= project.project_type %></p>
            <% if project.launch_date %>
              <p class="text-xs text-slate-500">Launch: <%= project.launch_date.strftime("%B %d, %Y") %></p>
            <% end %>
          </a>
        <% end %>
      </div>
    <% else %>
      <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-16 text-center">
        <div class="w-16 h-16 bg-indigo-500/15 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-slate-50">No projects yet</h3>
        <p class="mt-2 text-slate-500 text-sm">Your projects will appear here once your team sets them up.</p>
      </div>
    <% end %>
  </div>
</div>
