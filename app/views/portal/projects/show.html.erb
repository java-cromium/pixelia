<% content_for(:title) { "#{@project.name} — Pixelia" } %>

<div class="min-h-screen bg-slate-900">
  <!-- Top Navigation -->
  <nav class="bg-slate-950 border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="<%= portal_root_path %>"><%= image_tag "logo-landscape.png", alt: "Pixelia", class: "h-12 w-auto" %></a>
        <span class="text-xs font-medium text-cyan-400 bg-cyan-500/10 px-2 py-1 rounded-full">Portal</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="<%= projects_path %>" class="text-sm font-medium text-slate-400 hover:text-cyan-400 transition-colors">Projects</a>
        <a href="<%= ecommerce_stores_path %>" class="text-sm font-medium text-slate-400 hover:text-cyan-400 transition-colors">Stores</a>
        <% if current_user %>
          <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-red-400 hover:text-red-300 transition-colors" %>
        <% end %>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 py-10">
    <!-- Breadcrumb -->
    <div class="mb-6">
      <a href="<%= projects_path %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">&larr; Back to Projects</a>
    </div>

    <!-- Project Header -->
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 mb-8">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-3xl font-bold text-slate-50"><%= @project.name %></h1>
          <p class="mt-2 text-slate-400"><%= @project.project_type %></p>
        </div>
        <span class="text-sm font-medium px-4 py-2 rounded-full
          <%= @project.status == 'active' ? 'bg-emerald-500/15 text-emerald-400' : 'bg-slate-700 text-slate-400' %>">
          <%= @project.status&.capitalize || "N/A" %>
        </span>
      </div>

      <div class="mt-6 grid sm:grid-cols-3 gap-6 pt-6 border-t border-slate-700/50">
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Type</p>
          <p class="mt-1 text-sm font-semibold text-slate-50"><%= @project.project_type || "—" %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Launch Date</p>
          <p class="mt-1 text-sm font-semibold text-slate-50"><%= @project.launch_date&.strftime("%B %d, %Y") || "TBD" %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">E-Commerce Stores</p>
          <p class="mt-1 text-sm font-semibold text-slate-50"><%= @project.ecommerce_stores.count %></p>
        </div>
      </div>
    </div>

    <!-- Linked E-Commerce Stores -->
    <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-slate-50 mb-6">Linked E-Commerce Stores</h2>
      <% if @project.ecommerce_stores.any? %>
        <div class="divide-y divide-slate-700/50">
          <% @project.ecommerce_stores.each do |store| %>
            <div class="py-4 flex items-center justify-between">
              <div>
                <p class="font-medium text-slate-50"><%= store.platform %></p>
                <p class="text-sm text-slate-500"><%= store.store_url %></p>
              </div>
              <a href="<%= ecommerce_store_path(store) %>" class="text-sm font-medium text-cyan-400 hover:text-cyan-300">View &rarr;</a>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-slate-500 text-sm">No stores connected to this project yet.</p>
      <% end %>
    </div>
  </div>
</div>
