<% content_for(:title) { "Sites — Pixelia" } %>

<div class="p-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50">Sites</h1>
    <p class="mt-1 text-brand-text-light dark:text-slate-400">Your published websites and landing pages.</p>
  </div>

  <% if @sites.any? %>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @sites.each do |site| %>
        <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-6 shadow-sm dark:shadow-none transition-all duration-200 hover:border-brand-highlight/50 hover:shadow-lg hover:shadow-brand-highlight/5">
          <a href="<%= portal_site_path(site) %>" class="block">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-brand-highlight/15 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-brand-highlight dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-brand-text dark:text-slate-50"><%= site.name %></h3>
                <p class="text-xs text-brand-text-light dark:text-slate-500"><%= site.domain_display || "No domain" %></p>
              </div>
            </div>
          </a>

          <div class="pt-4 border-t border-brand-border dark:border-slate-700/50">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= site.published? ? 'bg-emerald-500/15 text-emerald-600 dark:text-emerald-400' : 'bg-brand-card-alt dark:bg-slate-700 text-brand-text-light dark:text-slate-400' %>">
                <%= site.published? ? "Published" : "Draft" %>
              </span>
              <span class="text-xs text-brand-text-light dark:text-slate-500"><%= site.pages.count %> pages</span>
            </div>

            <div class="flex items-center gap-2">
              <% if site.pages.any? %>
                <a href="<%= editor_portal_site_page_path(site, site.pages.first) %>" class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-brand-highlight text-white text-xs font-semibold rounded-lg hover:bg-brand-highlight-hover transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  Edit Site
                </a>
              <% else %>
                <a href="<%= build_wizard_portal_site_path(site) %>" class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-brand-highlight text-white text-xs font-semibold rounded-lg hover:bg-brand-highlight-hover transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  Quick Build
                </a>
              <% end %>
              <a href="<%= portal_site_path(site) %>" class="inline-flex items-center justify-center px-3 py-2 bg-brand-card-alt dark:bg-slate-700 text-brand-text-muted dark:text-slate-300 text-xs font-medium rounded-lg hover:bg-brand-border dark:hover:bg-slate-600 transition-colors">
                Manage
              </a>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-16 text-center shadow-sm dark:shadow-none">
      <div class="w-16 h-16 bg-brand-highlight/15 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-brand-highlight dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-brand-text dark:text-slate-50">No sites yet</h3>
      <p class="mt-2 text-brand-text-light dark:text-slate-500 text-sm">Your websites will appear here once created.</p>
    </div>
  <% end %>
</div>
