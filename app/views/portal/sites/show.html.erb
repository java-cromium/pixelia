<% content_for(:title) { "#{@site.name} — Pixelia" } %>

<div class="p-8">
  <div class="mb-6">
    <a href="<%= portal_sites_path %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">&larr; Back to Sites</a>
  </div>

  <!-- Site Header -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 mb-8">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 bg-cyan-500/15 rounded-xl flex items-center justify-center">
          <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-slate-50"><%= @site.name %></h1>
          <p class="text-slate-400"><%= @site.domain_display || "No domain configured" %></p>
        </div>
      </div>
      <span class="text-xs font-medium px-3 py-1.5 rounded-full <%= @site.published? ? 'bg-emerald-500/15 text-emerald-400' : 'bg-slate-700 text-slate-400' %>">
        <%= @site.published? ? "Published" : "Draft" %>
      </span>
    </div>

    <div class="grid sm:grid-cols-3 gap-6 pt-6 border-t border-slate-700/50">
      <div>
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Subdomain</p>
        <p class="mt-1 text-sm font-semibold text-slate-50"><%= @site.subdomain.present? ? "#{@site.subdomain}.pixelia.com" : "—" %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Custom Domain</p>
        <p class="mt-1 text-sm font-semibold text-slate-50"><%= @site.custom_domain.presence || "—" %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Pages</p>
        <p class="mt-1 text-sm font-semibold text-slate-50"><%= @site.pages.count %></p>
      </div>
    </div>
  </div>

  <!-- Custom Domain Management -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 mb-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-lg font-bold text-slate-50">Custom Domain</h2>
        <p class="text-sm text-slate-400 mt-1">Connect your own domain to this site.</p>
      </div>
      <% if @site.domain_configured? %>
        <a href="<%= portal_site_domain_path(@site) %>" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">Refresh Status</a>
      <% end %>
    </div>

    <% if @site.domain_configured? %>
      <!-- Domain Status -->
      <div class="rounded-xl border border-slate-700/50 bg-slate-900/50 p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-2.5 h-2.5 rounded-full <%= @site.domain_active? ? 'bg-emerald-400' : 'bg-amber-400 animate-pulse' %>"></span>
          <span class="font-semibold text-slate-50"><%= @site.custom_domain %></span>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">Hostname Status</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium <%= @site.domain_status == 'active' ? 'text-emerald-400' : 'text-amber-400' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= @site.domain_status == 'active' ? 'bg-emerald-400' : 'bg-amber-400' %>"></span>
              <%= @site.domain_status&.titleize || "Unknown" %>
            </span>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">SSL Status</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium <%= @site.ssl_status == 'active' ? 'text-emerald-400' : 'text-amber-400' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= @site.ssl_status == 'active' ? 'bg-emerald-400' : 'bg-amber-400' %>"></span>
              <%= @site.ssl_status&.titleize || "Unknown" %>
            </span>
          </div>
        </div>

        <% if @site.domain_verification_errors.present? && @site.domain_verification_errors.any? %>
          <div class="mt-4 p-3 bg-red-500/10 border border-red-500/30 rounded-lg">
            <p class="text-sm text-red-400 font-medium mb-1">Verification Errors</p>
            <% @site.domain_verification_errors.each do |err| %>
              <p class="text-xs text-red-300"><%= err %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <% unless @site.domain_active? %>
        <!-- DNS Instructions -->
        <div class="rounded-xl border border-indigo-500/30 bg-indigo-500/5 p-6 mb-6">
          <h3 class="text-sm font-bold text-indigo-300 mb-3">
            <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            DNS Configuration Required
          </h3>
          <p class="text-sm text-slate-400 mb-4">Add the following CNAME record at your DNS provider:</p>
          <div class="bg-slate-900 rounded-lg p-4 font-mono text-sm">
            <div class="grid grid-cols-3 gap-4 text-slate-500 text-xs mb-2">
              <span>Type</span><span>Name</span><span>Target</span>
            </div>
            <div class="grid grid-cols-3 gap-4 text-slate-50">
              <span class="text-cyan-400">CNAME</span>
              <span><%= @site.custom_domain %></span>
              <span class="text-emerald-400"><%= @site.cname_target %></span>
            </div>
          </div>
          <p class="text-xs text-slate-500 mt-3">DNS changes can take up to 24 hours to propagate. Status will update automatically.</p>
        </div>
      <% end %>

      <!-- Remove Domain -->
      <%= button_to "Remove Custom Domain", portal_site_domain_path(@site), method: :delete,
          class: "text-sm text-red-400 hover:text-red-300 font-medium",
          data: { turbo_confirm: "Are you sure you want to remove this custom domain?" } %>

    <% else %>
      <!-- Add Domain Form -->
      <%= form_with url: portal_site_domain_path(@site), method: :post, scope: :domain, class: "space-y-4" do |f| %>
        <div>
          <label for="custom_domain" class="block text-sm font-medium text-slate-300 mb-2">Domain Name</label>
          <div class="flex gap-3">
            <%= f.text_field :custom_domain,
                placeholder: "www.example.com",
                class: "flex-1 bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-slate-50 placeholder-slate-600 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:ring-offset-0 transition-colors",
                required: true %>
            <%= f.submit "Connect Domain",
                class: "px-6 py-2.5 bg-indigo-600 text-sm font-semibold text-white rounded-xl hover:bg-indigo-500 transition-colors cursor-pointer" %>
          </div>
          <p class="mt-2 text-xs text-slate-500">Enter the full domain (e.g. www.example.com or shop.mybrand.com). After submitting, you'll receive DNS instructions.</p>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Pages List -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8">
    <h2 class="text-lg font-bold text-slate-50 mb-6">Pages</h2>
    <% if @site.pages.any? %>
      <div class="divide-y divide-slate-700/50">
        <% @site.pages.order(:title).each do |page| %>
          <div class="py-3 flex items-center justify-between">
            <div>
              <p class="font-medium text-slate-50"><%= page.title %></p>
              <p class="text-xs text-slate-500">/<%= page.slug %></p>
            </div>
            <% if @site.published? && @site.subdomain.present? %>
              <a href="<%= site_preview_path(@site.subdomain) %>/<%= page.slug %>" target="_blank" class="text-sm text-cyan-400 hover:text-cyan-300 font-medium">Preview</a>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-500 text-sm text-center py-4">No pages created yet.</p>
    <% end %>
  </div>
</div>
