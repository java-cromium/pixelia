<% content_for(:title) { "Settings — Pixelia" } %>

<div class="p-8">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-slate-50">Account Settings</h1>
    <p class="mt-2 text-slate-400">Manage your organization profile and preferences.</p>
  </div>

  <!-- Account Info -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 mb-8">
    <h2 class="text-lg font-bold text-slate-50 mb-6">Organization</h2>

    <%= form_with model: @account, url: portal_settings_path, method: :patch, class: "space-y-6" do |f| %>
      <% if @account.errors.any? %>
        <div class="p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
          <ul class="list-disc list-inside text-sm text-red-400 space-y-1">
            <% @account.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Company Name", class: "block text-sm font-semibold text-slate-300 mb-2" %>
        <%= f.text_field :name, class: "w-full max-w-md px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
      </div>

      <div>
        <%= f.label :industry, "Industry", class: "block text-sm font-semibold text-slate-300 mb-2" %>
        <%= f.text_field :industry, class: "w-full max-w-md px-4 py-3 rounded-xl bg-slate-900 border border-slate-700 text-slate-50 placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow", placeholder: "e.g. E-Commerce, SaaS, Retail" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Save Changes", class: "px-6 py-3 bg-indigo-600 text-slate-50 font-semibold rounded-xl shadow-lg shadow-indigo-600/25 hover:bg-indigo-500 transition-all duration-200 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <!-- Account Details (read-only) -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 mb-8">
    <h2 class="text-lg font-bold text-slate-50 mb-6">Subscription</h2>
    <dl class="space-y-4">
      <div class="flex items-center justify-between">
        <dt class="text-sm font-medium text-slate-500">Plan</dt>
        <dd class="text-sm font-semibold text-slate-50"><%= @account.plan.capitalize %></dd>
      </div>
      <div class="flex items-center justify-between border-t border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-slate-500">Status</dt>
        <dd class="text-sm font-semibold <%= subscription_status_class(@account.subscription_status) %>"><%= @account.subscription_status.capitalize %></dd>
      </div>
      <% if @account.trial_ends_at.present? %>
        <div class="flex items-center justify-between border-t border-slate-700/50 pt-4">
          <dt class="text-sm font-medium text-slate-500">Trial Ends</dt>
          <dd class="text-sm text-slate-50"><%= @account.trial_ends_at.strftime("%B %d, %Y") %></dd>
        </div>
      <% end %>
    </dl>
    <div class="mt-6 pt-6 border-t border-slate-700/50">
      <a href="<%= portal_billing_path %>" class="text-sm font-medium text-cyan-400 hover:text-cyan-300">Manage billing &rarr;</a>
    </div>
  </div>

  <!-- Integrations -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 mb-8">
    <h2 class="text-lg font-bold text-slate-50 mb-6">Integrations</h2>

    <!-- Google Ads -->
    <div class="flex items-center justify-between p-4 rounded-xl border border-slate-700/50 bg-slate-900/50">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 bg-blue-500/15 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/></svg>
        </div>
        <div>
          <p class="font-medium text-slate-50">Google Ads</p>
          <% if @account.google_ad_account&.connected? %>
            <p class="text-xs text-emerald-400">Connected as <%= @account.google_ad_account.google_email %></p>
          <% else %>
            <p class="text-xs text-slate-500">Connect to manage ad campaigns</p>
          <% end %>
        </div>
      </div>
      <div>
        <% if @account.google_ad_account&.connected? %>
          <%= button_to "Disconnect", portal_google_ads_disconnect_path, method: :delete,
              class: "text-sm text-red-400 hover:text-red-300 font-medium",
              data: { turbo_confirm: "Disconnect Google Ads?" } %>
        <% else %>
          <%= button_to "Connect", "/auth/google_ads", method: :post,
              class: "px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-500 transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Team Members -->
  <div class="bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8">
    <h2 class="text-lg font-bold text-slate-50 mb-6">Team Members</h2>
    <div class="divide-y divide-slate-700/50">
      <% @account.users.each do |user| %>
        <div class="py-3 flex items-center justify-between">
          <div>
            <p class="font-medium text-slate-50"><%= user.email %></p>
            <p class="text-xs text-slate-500"><%= user.role.humanize %></p>
          </div>
          <% if user == current_user %>
            <span class="text-xs font-medium text-slate-500 bg-slate-700 px-2.5 py-1 rounded-full">You</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
