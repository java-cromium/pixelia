<% content_for(:title) { "Settings — Pixelia" } %>

<div class="p-8">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50">Account Settings</h1>
    <p class="mt-2 text-brand-text-light dark:text-slate-400">Manage your organization profile and preferences.</p>
  </div>

  <!-- Account Info -->
  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 mb-8 shadow-sm dark:shadow-none">
    <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">Organization</h2>

    <%= form_with model: @account, url: portal_settings_path, method: :patch, class: "space-y-6" do |f| %>
      <% if @account.errors.any? %>
        <div class="p-4 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 rounded-xl">
          <ul class="list-disc list-inside text-sm text-red-600 dark:text-red-400 space-y-1">
            <% @account.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Company Name", class: "block text-sm font-semibold text-brand-text-muted dark:text-slate-300 mb-2" %>
        <%= f.text_field :name, class: "w-full max-w-md px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-slate-400 dark:placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
      </div>

      <div>
        <%= f.label :industry, "Industry", class: "block text-sm font-semibold text-brand-text-muted dark:text-slate-300 mb-2" %>
        <%= f.text_field :industry, class: "w-full max-w-md px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-slate-400 dark:placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow", placeholder: "e.g. E-Commerce, SaaS, Retail" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Save Changes", class: "px-6 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all duration-200 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <!-- Account Details (read-only) -->
  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 mb-8 shadow-sm dark:shadow-none">
    <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">Subscription</h2>
    <dl class="space-y-4">
      <div class="flex items-center justify-between">
        <dt class="text-sm font-medium text-brand-text-light dark:text-slate-500">Plan</dt>
        <dd class="text-sm font-semibold text-brand-text dark:text-slate-50"><%= @account.plan.capitalize %></dd>
      </div>
      <div class="flex items-center justify-between border-t border-brand-border dark:border-slate-700/50 pt-4">
        <dt class="text-sm font-medium text-brand-text-light dark:text-slate-500">Status</dt>
        <dd class="text-sm font-semibold <%= subscription_status_class(@account.subscription_status) %>"><%= @account.subscription_status.capitalize %></dd>
      </div>
      <% if @account.trial_ends_at.present? %>
        <div class="flex items-center justify-between border-t border-brand-border dark:border-slate-700/50 pt-4">
          <dt class="text-sm font-medium text-brand-text-light dark:text-slate-500">Trial Ends</dt>
          <dd class="text-sm text-brand-text dark:text-slate-50"><%= @account.trial_ends_at.strftime("%B %d, %Y") %></dd>
        </div>
      <% end %>
    </dl>
    <div class="mt-6 pt-6 border-t border-brand-border dark:border-slate-700/50">
      <a href="<%= portal_billing_path %>" class="text-sm font-medium text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300">Manage billing &rarr;</a>
    </div>
  </div>

  <!-- Integrations -->
  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 mb-8 shadow-sm dark:shadow-none">
    <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">Integrations</h2>

    <!-- Google Ads -->
    <div class="p-4 rounded-xl border border-brand-border dark:border-slate-700/50 bg-brand-card-alt dark:bg-slate-900/50">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-brand-highlight/15 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-highlight dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M3.2 21L10.8 3h2.4l7.6 18h-2.8l-1.6-4H7.6L6 21H3.2zm5.2-6.4h7.2L12 5.8l-3.6 8.8zM19.2 8.4a2.4 2.4 0 1 0 0-4.8 2.4 2.4 0 0 0 0 4.8z"/></svg>
          </div>
          <div>
            <p class="font-medium text-brand-text dark:text-slate-50">Google Ads</p>
            <% google_accounts = @account.google_ad_accounts.connected %>
            <% if google_accounts.any? %>
              <p class="text-xs text-emerald-600 dark:text-emerald-400"><%= google_accounts.count %> account<%= google_accounts.count > 1 ? "s" : "" %> linked</p>
            <% else %>
              <p class="text-xs text-brand-text-light dark:text-slate-500">Connect to manage ad campaigns</p>
            <% end %>
          </div>
        </div>
        <div>
          <%= button_to "Connect", "/auth/google_ads", method: :post,
              data: { turbo: false },
              class: "px-4 py-2 bg-brand-highlight text-white text-sm font-semibold rounded-lg hover:bg-brand-highlight-hover transition-colors" %>
        </div>
      </div>
      <% if google_accounts.any? %>
        <div class="mt-3 pt-3 border-t border-brand-border/50 dark:border-slate-700/30 space-y-2">
          <% google_accounts.each do |ga| %>
            <div class="flex items-center justify-between pl-14">
              <div>
                <p class="text-xs font-medium text-brand-text dark:text-slate-300"><%= ga.display_name %></p>
                <p class="text-[11px] text-brand-text-light dark:text-slate-500">CID: <%= ga.formatted_customer_id || "—" %> · <%= ga.connection_type.upcase %></p>
              </div>
              <%= button_to "Disconnect", portal_google_ads_disconnect_path(ga), method: :delete,
                  class: "px-3 py-1.5 bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 text-xs font-semibold rounded-lg border border-red-200 dark:border-red-500/30 hover:bg-red-100 dark:hover:bg-red-500/20 transition-colors",
                  data: { turbo_confirm: "Disconnect this Google Ads account?" } %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Meta Ads -->
    <div class="flex items-center justify-between p-4 rounded-xl border border-brand-border dark:border-slate-700/50 bg-brand-card-alt dark:bg-slate-900/50 mt-4">
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 bg-brand-highlight/15 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-brand-highlight dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M6.915 4.03c-1.968 0-3.762 1.085-4.907 2.895C.877 8.737.2 10.97.2 13.395c0 2.424.678 4.658 1.808 6.47 1.145 1.81 2.94 2.895 4.907 2.895 1.208 0 2.347-.377 3.312-1.084.735-.538 1.36-1.245 1.865-2.08.506.836 1.13 1.542 1.865 2.08.965.707 2.104 1.084 3.312 1.084 1.968 0 3.762-1.085 4.907-2.895 1.13-1.812 1.808-4.046 1.808-6.47 0-2.424-.678-4.658-1.808-6.47-1.145-1.81-2.94-2.895-4.907-2.895-1.208 0-2.347.377-3.312 1.084-.735.538-1.36 1.245-1.865 2.08-.506-.835-1.13-1.542-1.865-2.08-.965-.707-2.104-1.084-3.312-1.084zm0 2.1c.746 0 1.5.26 2.168.755.66.488 1.235 1.18 1.674 2.013.545 1.03.886 2.257.994 3.596H4.08c.108-1.34.449-2.566.994-3.596.44-.833 1.014-1.525 1.674-2.013.669-.496 1.422-.755 2.168-.755zm10.17 0c.746 0 1.5.26 2.168.755.66.488 1.235 1.18 1.674 2.013.545 1.03.886 2.257.994 3.596h-7.672c.108-1.34.449-2.566.994-3.596.44-.833 1.014-1.525 1.674-2.013.669-.496 1.422-.755 2.168-.755zM4.08 14.494h7.672c-.108 1.34-.449 2.566-.994 3.596-.44.833-1.014 1.525-1.674 2.013-.669.496-1.422.755-2.168.755-.746 0-1.5-.26-2.168-.755-.66-.488-1.235-1.18-1.674-2.013-.545-1.03-.886-2.257-.994-3.596zm9.92 0h7.672c-.108 1.34-.449 2.566-.994 3.596-.44.833-1.014 1.525-1.674 2.013-.669.496-1.422.755-2.168.755-.746 0-1.5-.26-2.168-.755-.66-.488-1.235-1.18-1.674-2.013-.545-1.03-.886-2.257-.994-3.596z"/></svg>
        </div>
        <div>
          <p class="font-medium text-brand-text dark:text-slate-50">Meta Ads</p>
          <% if @account.meta_ad_account&.connected? %>
            <p class="text-xs text-emerald-600 dark:text-emerald-400">Connected as <%= @account.meta_ad_account.meta_email %></p>
          <% else %>
            <p class="text-xs text-brand-text-light dark:text-slate-500">Connect to manage Facebook & Instagram ads</p>
          <% end %>
        </div>
      </div>
      <div>
        <% if @account.meta_ad_account&.connected? %>
          <%= button_to "Disconnect", portal_meta_ads_disconnect_path, method: :delete,
              class: "px-4 py-2 bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 text-sm font-semibold rounded-lg border border-red-200 dark:border-red-500/30 hover:bg-red-100 dark:hover:bg-red-500/20 transition-colors",
              data: { turbo_confirm: "Disconnect Meta Ads?" } %>
        <% else %>
          <%= button_to "Connect", "/auth/meta_ads", method: :post,
              class: "px-4 py-2 bg-brand-highlight text-white text-sm font-semibold rounded-lg hover:bg-brand-highlight-hover transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- AI Provider -->
  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 mb-8 shadow-sm dark:shadow-none">
    <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-2">AI Content Generation</h2>
    <p class="text-sm text-brand-text-light dark:text-slate-400 mb-6">Add your AI provider API key to generate website content in the Quick Build wizard.</p>

    <%= form_with model: @account, url: portal_settings_path, method: :patch, class: "space-y-5", data: { turbo: false } do |f| %>
      <div>
        <%= f.label :ai_provider, "AI Provider", class: "block text-sm font-semibold text-brand-text-muted dark:text-slate-300 mb-2" %>
        <%= f.select :ai_provider,
          options_for_select([
            ["Select a provider...", ""],
            ["OpenAI (ChatGPT)", "openai"],
            ["Google Gemini", "gemini"],
            ["Anthropic (Claude)", "claude"]
          ], @account.ai_provider),
          {},
          class: "w-full max-w-md px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
      </div>

      <div>
        <%= f.label :ai_api_key, "API Key", class: "block text-sm font-semibold text-brand-text-muted dark:text-slate-300 mb-2" %>
        <%= f.password_field :ai_api_key,
          placeholder: @account.ai_api_key.present? ? "••••••••••••••••" : "Paste your API key here",
          value: "",
          class: "w-full max-w-md px-4 py-3 rounded-xl bg-brand-card-alt dark:bg-slate-900 border border-brand-border dark:border-slate-700 text-brand-text dark:text-slate-50 placeholder-slate-400 dark:placeholder-slate-500 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-shadow" %>
        <p class="mt-1.5 text-xs text-brand-text-light dark:text-slate-500">
          Your key is encrypted and stored securely. Leave blank to keep your existing key.
        </p>
        <p class="mt-1 text-xs text-brand-text-light dark:text-slate-500">
          <a href="https://platform.openai.com/api-keys" target="_blank" class="text-brand-highlight hover:underline">OpenAI</a> &middot;
          <a href="https://aistudio.google.com/app/apikey" target="_blank" class="text-brand-highlight hover:underline">Google Gemini</a> &middot;
          <a href="https://console.anthropic.com/settings/keys" target="_blank" class="text-brand-highlight hover:underline">Anthropic Claude</a>
        </p>
      </div>

      <% if @account.ai_configured? %>
        <div class="flex items-center gap-2 p-3 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/30 rounded-xl">
          <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm font-medium text-emerald-700 dark:text-emerald-400"><%= @account.ai_provider.capitalize %> connected — AI content generation is available in Quick Build.</span>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Save AI Settings", class: "px-6 py-3 bg-brand-highlight text-white font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all duration-200 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <!-- Team Members -->
  <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 shadow-sm dark:shadow-none">
    <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">Team Members</h2>
    <div class="divide-y divide-brand-border dark:divide-slate-700/50">
      <% @account.users.each do |user| %>
        <div class="py-3 flex items-center justify-between">
          <div>
            <p class="font-medium text-brand-text dark:text-slate-50"><%= user.email %></p>
            <p class="text-xs text-brand-text-light dark:text-slate-500"><%= user.role.humanize %></p>
          </div>
          <% if user == current_user %>
            <span class="text-xs font-medium text-brand-text-light bg-brand-card-alt dark:bg-slate-700 px-2.5 py-1 rounded-full">You</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
