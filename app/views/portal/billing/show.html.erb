<% content_for(:title) { "Billing — Pixelia" } %>

<div class="p-8">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-brand-text dark:text-slate-50">Billing & Subscription</h1>
    <p class="mt-2 text-brand-text-light dark:text-slate-400">Manage your plan, payment method, and invoices.</p>
  </div>

    <!-- Current Plan -->
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8 mb-8">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-medium text-brand-text-light dark:text-slate-500 uppercase tracking-wider">Current Plan</p>
          <p class="mt-2 text-2xl font-bold text-brand-text dark:text-slate-50"><%= @account.plan.capitalize %></p>
          <p class="mt-1 text-sm text-brand-text-light dark:text-slate-400">
            Status:
            <span class="font-medium <%= @account.subscription_status == 'active' ? 'text-emerald-600 dark:text-emerald-400' : @account.subscription_status == 'trialing' ? 'text-brand-highlight dark:text-cyan-400' : 'text-amber-600 dark:text-amber-400' %>">
              <%= @account.subscription_status.capitalize %>
            </span>
            <% if @account.trial_ends_at.present? && @account.subscription_status == "trialing" %>
              <span class="text-slate-500">(ends <%= @account.trial_ends_at.strftime("%b %d, %Y") %>)</span>
            <% end %>
          </p>
        </div>
        <% unless @account.on_free_plan? %>
          <%= button_to "Manage Payment", portal_billing_portal_path, method: :post, class: "px-5 py-2.5 bg-brand-card-alt dark:bg-slate-700 border border-brand-border dark:border-slate-600 text-sm font-semibold text-brand-text-muted dark:text-slate-300 rounded-xl hover:bg-brand-border dark:hover:bg-slate-600 transition-colors cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <!-- Pricing Plans -->
    <div class="mb-12">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">Choose a Plan</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Free -->
        <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border <%= @account.plan == 'free' ? 'border-brand-highlight/50' : 'border-brand-border dark:border-slate-700/50' %> p-8 relative">
          <% if @account.plan == "free" %>
            <span class="absolute top-4 right-4 text-xs font-medium text-brand-highlight dark:text-indigo-400 bg-brand-highlight/15 dark:bg-indigo-500/15 px-2.5 py-1 rounded-full">Current</span>
          <% end %>
          <h3 class="text-xl font-bold text-brand-text dark:text-slate-50">Free</h3>
          <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50">$0<span class="text-sm font-normal text-brand-text-light dark:text-slate-500">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-brand-text-muted dark:text-slate-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              1 site
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              1 e-commerce store
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Basic analytics
            </li>
          </ul>
          <div class="mt-8">
            <span class="block w-full text-center px-5 py-3 text-sm font-semibold text-brand-text-light dark:text-slate-500 bg-brand-card-alt dark:bg-slate-700/50 rounded-xl">No card needed</span>
          </div>
        </div>

        <!-- Starter -->
        <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border <%= @account.plan == 'starter' ? 'border-brand-highlight/50' : 'border-brand-border dark:border-slate-700/50' %> p-8 relative">
          <% if @account.plan == "starter" %>
            <span class="absolute top-4 right-4 text-xs font-medium text-brand-highlight dark:text-indigo-400 bg-brand-highlight/15 dark:bg-indigo-500/15 px-2.5 py-1 rounded-full">Current</span>
          <% end %>
          <h3 class="text-xl font-bold text-brand-text dark:text-slate-50">Starter</h3>
          <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50">$49<span class="text-sm font-normal text-brand-text-light dark:text-slate-500">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-brand-text-muted dark:text-slate-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              3 sites
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              3 e-commerce stores
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Custom domains
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Priority support
            </li>
          </ul>
          <div class="mt-8">
            <% if @account.plan == "starter" %>
              <span class="block w-full text-center px-5 py-3 text-sm font-semibold text-emerald-400 bg-emerald-500/15 rounded-xl">Active</span>
            <% else %>
              <%= button_to "Upgrade to Starter", portal_billing_checkout_path(plan: "starter"), method: :post, class: "w-full px-5 py-3 bg-brand-highlight text-white text-sm font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all cursor-pointer" %>
            <% end %>
          </div>
        </div>

        <!-- Growth -->
        <div class="bg-gradient-to-b from-brand-highlight/10 dark:from-indigo-500/10 to-brand-card dark:to-slate-800/50 rounded-2xl border <%= @account.plan == 'growth' ? 'border-brand-highlight/50' : 'border-brand-highlight/30 dark:border-indigo-500/30' %> p-8 relative">
          <% if @account.plan == "growth" %>
            <span class="absolute top-4 right-4 text-xs font-medium text-brand-highlight dark:text-indigo-400 bg-brand-highlight/15 dark:bg-indigo-500/15 px-2.5 py-1 rounded-full">Current</span>
          <% else %>
            <span class="absolute top-4 right-4 text-xs font-medium text-brand-highlight dark:text-indigo-400 bg-brand-highlight/15 dark:bg-indigo-500/15 px-2.5 py-1 rounded-full">Popular</span>
          <% end %>
          <h3 class="text-xl font-bold text-brand-text dark:text-slate-50">Growth</h3>
          <p class="mt-2 text-3xl font-bold text-brand-text dark:text-slate-50">$149<span class="text-sm font-normal text-brand-text-light dark:text-slate-500">/mo</span></p>
          <ul class="mt-6 space-y-3 text-sm text-brand-text-muted dark:text-slate-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Unlimited sites
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Unlimited stores
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Google & Meta Ads
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Dedicated account manager
            </li>
          </ul>
          <div class="mt-8">
            <% if @account.plan == "growth" %>
              <span class="block w-full text-center px-5 py-3 text-sm font-semibold text-emerald-400 bg-emerald-500/15 rounded-xl">Active</span>
            <% else %>
              <%= button_to "Upgrade to Growth", portal_billing_checkout_path(plan: "growth"), method: :post, class: "w-full px-5 py-3 bg-brand-highlight text-white text-sm font-semibold rounded-xl shadow-lg shadow-brand-highlight/25 hover:bg-brand-highlight-hover transition-all cursor-pointer" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Charges -->
    <div class="bg-brand-card dark:bg-slate-800/50 rounded-2xl border border-brand-border dark:border-slate-700/50 p-8">
      <h2 class="text-lg font-bold text-brand-text dark:text-slate-50 mb-6">Payment History</h2>
      <% if @charges.any? %>
        <table class="w-full">
          <thead>
            <tr class="text-left text-xs font-medium text-brand-text-light dark:text-slate-500 uppercase tracking-wider border-b border-brand-border dark:border-slate-700">
              <th class="pb-3">Date</th>
              <th class="pb-3">Amount</th>
              <th class="pb-3">Status</th>
              <th class="pb-3">Receipt</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-brand-border dark:divide-slate-700/50">
            <% @charges.each do |charge| %>
              <tr class="hover:bg-brand-card-alt dark:hover:bg-slate-700/30">
                <td class="py-3 text-sm text-brand-text-muted dark:text-slate-400"><%= charge.created_at.strftime("%b %d, %Y") %></td>
                <td class="py-3 text-sm font-medium text-brand-text dark:text-slate-50"><%= number_to_currency(charge.amount / 100.0) %></td>
                <td class="py-3">
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-emerald-500/15 text-emerald-400">Paid</span>
                </td>
                <td class="py-3">
                  <% if charge.receipt_url.present? %>
                    <a href="<%= charge.receipt_url %>" target="_blank" class="text-sm text-brand-highlight dark:text-cyan-400 hover:text-brand-highlight-hover dark:hover:text-cyan-300 font-medium">View</a>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-brand-text-light dark:text-slate-500 text-sm text-center py-4">No payment history yet.</p>
      <% end %>
    </div>
</div>
