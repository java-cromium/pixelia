# ── Pixelia Production Environment Variables ─────────────────────
#
# Copy this file to .env and fill in the values for your deployment.
#
# ── Application ──────────────────────────────────────────────────
RAILS_ENV=production
RAILS_LOG_LEVEL=info
SECRET_KEY_BASE=      # Run: rails secret
APP_HOST=pixelia.com  # Your production domain

# ── Database (PostgreSQL) ────────────────────────────────────────
PIXELIA_DATABASE_PASSWORD=     # Production DB password
# Or use a full URL:
# DATABASE_URL=postgres://pixelia:PASSWORD@db-host:5432/pixelia_production

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SMTP (Email) ─────────────────────────────────────────────────
# SMTP credentials are stored in Rails credentials (rails credentials:edit)
# The following override the defaults if needed:
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
# In credentials.yml.enc, add:
#   smtp:
#     user_name: your-email@gmail.com
#     password: your-app-password

# ── Active Record Encryption ────────────────────────────────────
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=       # rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY= # rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT= # rails db:encryption:init

# ── Puma / Concurrency ──────────────────────────────────────────
PORT=3000
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
# SOLID_QUEUE_IN_PUMA=1  # Uncomment if NOT running Sidekiq separately
